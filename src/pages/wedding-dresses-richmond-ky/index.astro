  <style>
    /* ═════════════════════════════════════════════════════════════════════ */
    /* SECTION BASE STYLES - CONSISTENT PADDING */
    /* ═════════════════════════════════════════════════════════════════════ */
    .boutique-intro,
    .collection-section,
    .cta-block,
    .integrated-services,
    .bridal-experience,
    .reviews-section {
      padding: var(--space-12) var(--space-6);
    }

    /* ═════════════════════════════════════════════════════════════════════ */
    /* BOUTIQUE INTRO SECTION */
    /* ═════════════════════════════════════════════════════════════════════ */
    .boutique-intro__container {
      max-width: 70ch;
      margin: 0 auto;
    }

    .boutique-intro__heading {
      margin-bottom: var(--space-6);
    }

    .boutique-intro__text {
      margin-bottom: var(--space-6);
      font-size: 1.0625rem;
      line-height: var(--lh-loose);
      color: var(--color-charcoal);
    }

    /* ═════════════════════════════════════════════════════════════════════ */
    /* BRIDAL EXPERIENCE SECTION */
    /* ═════════════════════════════════════════════════════════════════════ */
