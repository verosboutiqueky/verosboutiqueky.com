        ShopifyBuy.UI.onReady(client).then(function (ui) {
          // Function to hide skeleton loaders when collection mounts
          function hideSkeleton(mountPointId, skeletonId) {
            var mountPoint = document.getElementById(mountPointId);
            var skeleton = document.getElementById(skeletonId);
            if (mountPoint && skeleton) {
              var observer = new MutationObserver(function(mutations) {
                if (mountPoint.children.length > 0) {
