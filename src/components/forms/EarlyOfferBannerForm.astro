---
// src/components/forms/EarlyOfferBannerForm.astro
// Early Offer Banner Form - Two-step dropdown form
// Step 1: Email (always visible)
// Step 2: First Name, Last Name, Phone (reveals on email focus/input)
// Posts to /api/lead with formType="early_offer"

const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "0x4AAAAAACWIZrFF9GFEC74s";
---

<div class="early-offer-banner" id="early-offer-banner">
  <button 
    class="early-offer-banner__close" 
    aria-label="Close announcement"
    id="early-offer-close">
    ×
  </button>
  <div class="early-offer-banner__content">
    <form class="early-offer-form" method="POST" action="/api/lead">
      {/* Hidden input for form type */}
      <input type="hidden" name="formType" value="early_offer" />

      {/* STEP 1: Always visible */}
      <div class="early-offer-form__step-1">
        <h3 class="early-offer-form__headline"> PROM SHOPPERS · CLAIM EXCLUSIVE 10% DISCOUNT </h3>
        
        <div class="early-offer-form__subtext-input-group">
          <p class="early-offer-form__subtext">Enter email for an exclusive early offer</p>
          <div class="early-offer-form__primary-input-group">
            <label for="early-offer-email" class="sr-only">Email address</label>
            <input
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              class="early-offer-form__input early-offer-form__email-input"
              id="early-offer-email"
            />
          </div>
        </div>
      </div>

      {/* STEP 2: Hidden until email focus/input */}
      <div class="early-offer-form__step-2" id="early-offer-step-2">
        <div class="early-offer-form__secondary-inputs">
          <input
            type="text"
            name="firstName"
            placeholder="First Name"
            class="early-offer-form__input"
          />
          <input
            type="text"
            name="lastName"
            placeholder="Last Name"
            class="early-offer-form__input"
          />
          <input
            type="tel"
            name="phone"
            placeholder="Phone Number"
            class="early-offer-form__input"
          />
        </div>

        {/* Turnstile CAPTCHA - Hidden until step-2 expands */}
        <div class="early-offer-form__turnstile-cta">
          <div
            data-turnstile-placeholder
            data-sitekey={siteKey}>
          </div>
        </div>
      </div>

      {/* CTA Button */}
      <button type="submit" class="early-offer-form__submit button button--primary">
        Unlock Offer
      </button>
    </form>
  </div>
</div>

<script>
  // Initialize banner dismissal behavior
  function initBanner() {
    const banner = document.getElementById('early-offer-banner');
    const closeBtn = document.getElementById('early-offer-close');
    
    // Handle close button click
    if (closeBtn) {
      closeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        if (banner) {
          banner.classList.add('is-dismissed');
          localStorage.setItem('earlyOfferBannerDismissed', 'true');
          // Collapse banner with animation
          setTimeout(() => {
            banner.style.display = 'none';
          }, 300);
        }
      });
    }
  }

  // Restore banner visibility on page load (clear persistent dismissal for testing)
  // In production, you can uncomment the localStorage check below to respect user dismissal
  function restoreBannerState() {
    const banner = document.getElementById('early-offer-banner');
    // Uncomment this line in production to hide banner if user previously dismissed it:
    // if (localStorage.getItem('earlyOfferBannerDismissed') === 'true' && banner) {
    //   banner.style.display = 'none';
    //   return;
    // }
    // For now, always show banner on load so it's visible
    if (banner) {
      banner.style.display = 'block';
    }
  }

  // Add keyboard support for close button
  document.addEventListener('DOMContentLoaded', () => {
    const closeBtn = document.getElementById('early-offer-close');
    if (closeBtn) {
      closeBtn.addEventListener('keydown', (e) => {
        // Trigger click on Enter or Space
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          closeBtn.click();
        }
      });
    }
  });

  // Handle Step 2 reveal on email focus/input
  const emailInput = document.getElementById('early-offer-email') as HTMLInputElement | null;
  const step2 = document.getElementById('early-offer-step-2');

  if (emailInput && step2) {
    // Show Step 2 on focus & load Turnstile
    emailInput.addEventListener('focus', () => {
      step2.classList.add('is-expanded');
      if (window.loadTurnstile) {
        window.loadTurnstile();
      }
    });

    // Show Step 2 if email has any value & load Turnstile
    emailInput.addEventListener('input', () => {
      if (emailInput.value.length > 0) {
        step2.classList.add('is-expanded');
        if (window.loadTurnstile) {
          window.loadTurnstile();
        }
      } else {
        step2.classList.remove('is-expanded');
      }
    });

    // Collapse Step 2 if email is cleared
    emailInput.addEventListener('blur', () => {
      if (emailInput.value.length === 0) {
        step2.classList.remove('is-expanded');
      }
    });
  }

  // Initialize on page load or Astro island hydration
  restoreBannerState();
  initBanner();
  document.addEventListener('astro:after-swap', () => {
    restoreBannerState();
    initBanner();
  });
</script>

<style>
  .early-offer-banner {
    background: linear-gradient(180deg, rgba(245, 241, 233, 0.55) 0%, rgba(245, 241, 233, 0.35) 100%);
    border-top: 1px solid var(--color-gold);
    border-bottom: 1px solid var(--color-gold);
    padding: 0.5rem 1.5rem;
    margin-top: calc(var(--header-height) + 20px);
    position: relative;
    z-index: 99;
    transition: opacity var(--transition-normal), max-height var(--transition-normal);
  }

  .early-offer-banner.is-dismissed {
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    padding: 0;
    border: none;
  }

  /* Close Button */
  .early-offer-banner__close {
    position: absolute;
    top: 0.5rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    color: var(--color-gold);
    padding: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color var(--transition-fast);
    z-index: 100;
  }

  .early-offer-banner__close:hover {
    color: var(--color-black);
  }

  .early-offer-banner__close:focus {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  .early-offer-banner__content {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .early-offer-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    max-width: 600px;
  }

  /* Step 1: Header and Email Input */
  .early-offer-form__step-1 {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
  }

  .early-offer-form__header {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .early-offer-form__subtext-input-group {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: baseline;
    justify-content: center;
  }

  .early-offer-form__headline {
    font-family: var(--font-serif);
    font-size: clamp(0.75rem, 2.2vw, 1rem) !important;
    font-weight: 400 !important;
    letter-spacing: 0.15em !important;
    text-transform: uppercase !important;
    color: var(--color-black);
    margin: 0 !important;
    line-height: 1.1;
    display: block;
    width: 100%;
    visibility: visible;
    opacity: 1;
  }

  .early-offer-form__subtext {
    font-family: var(--font-sans);
    font-size: clamp(0.7rem, 1.5vw, 0.8rem) !important;
    font-weight: 400 !important;
    color: var(--color-gray-medium);
    margin: 0 !important;
    line-height: 1.3;
    display: inline-block;
    white-space: normal;
    visibility: visible;
    opacity: 1;
  }

  .early-offer-form__primary-input-group {
    display: inline-flex;
    justify-content: center;
  }

  .early-offer-form__email-input {
    min-width: 160px;
    width: 100%;
    max-width: 220px;
  }

  /* Input Styles */
  .early-offer-form__input {
    padding: 0.45rem 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    border: 1px solid var(--color-gold);
    border-radius: 2px;
    background-color: white;
    color: var(--color-black);
    transition: all var(--transition-fast);
    height: auto;
  }

  .early-offer-form__input::placeholder {
    color: var(--color-gray-light);
  }

  .early-offer-form__input:focus {
    outline: none;
    border-color: var(--color-black);
    box-shadow: 0 0 0 3px rgba(197, 160, 89, 0.1);
  }

  /* Step 2: Secondary Inputs (Hidden by default) */
  .early-offer-form__step-2 {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height var(--transition-normal), opacity var(--transition-normal);
    pointer-events: none;
  }

  .early-offer-form__step-2.is-expanded {
    max-height: 300px;
    opacity: 1;
    pointer-events: auto;
  }

  .early-offer-form__secondary-inputs {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Submit Button */
  .early-offer-form__submit {
    margin-top: 0;
    width: 100%;
    max-width: 260px;
    align-self: center;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }

  /* Turnstile Wrapper - Minimal styling */
  .early-offer-form__turnstile-cta {
    display: flex;
    justify-content: center;
    margin-top: 0.25rem;
  }

  :global(.early-offer-form .cf-turnstile) {
    display: flex;
  }

  /* When mobile menu is open, constrain banner overflow to prevent layout thrash */
  html[data-menu-open="true"] .early-offer-banner {
    overflow-y: hidden;
  }

  /* Responsive: Tablet and up */
  @media (min-width: 640px) {
    .early-offer-banner {
      padding: 0.75rem 2rem;
    }

    .early-offer-form {
      gap: 0.75rem;
    }

    .early-offer-form__subtext-input-group {
      display: flex;
      flex-direction: row;
      gap: 0.5rem;
      align-items: baseline;
      justify-content: center;
    }

    .early-offer-form__primary-input-group {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
    }

    .early-offer-form__email-input {
      max-width: 280px;
    }

    .early-offer-form__secondary-inputs {
      display: flex;
      flex-direction: row;
      gap: 0.5rem;
    }

    .early-offer-form__input:not(.early-offer-form__email-input) {
      flex: 1;
      min-width: 100px;
    }

    .early-offer-form__submit {
      max-width: 240px;
    }
  }

  @media (min-width: 1024px) {
    .early-offer-banner {
      padding: 0.875rem 3rem;
    }

    .early-offer-form__headline {
      font-size: clamp(0.9rem, 2.3vw, 1.15rem);
    }

    .early-offer-form__subtext {
      font-size: clamp(0.8rem, 1.8vw, 0.95rem);
    }
  }
</style>
