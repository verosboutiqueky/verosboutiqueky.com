              "padding-bottom": "17px"
            }
          },
          "text": {
            "button": "Add to cart"
          }
        }
      };

      // Initialize Shopify collections with IntersectionObserver + first-interaction
      function initializeCollections() {
        // Prevent duplicate SDK loads
        if (window.__shopifyBuyButtonScriptLoaded) return;
        window.__shopifyBuyButtonScriptLoaded = true;

        // Load Shopify Buy Button SDK
        const script = document.createElement('script');
        script.src = 'https://sdks.shopifycdn.com/buy-button/latest/buy-button-storefront.min.js';
        script.async = true;

        script.onload = function() {
          // Iterate through each collection
          collections.forEach(function(collection) {
            // Guard against duplicate initialization
            if (window[collection.guard]) return;
            window[collection.guard] = true;

            const mountDiv = document.getElementById(collection.mountId);
            const skeletonDiv = document.getElementById(collection.skeletonId);

            if (!mountDiv) return;

            // Initialize ShopifyBuy
            if (typeof ShopifyBuy !== 'undefined') {
              const client = ShopifyBuy.buildClient({
                domain: 'drwakf-ge.myshopify.com',
                storefrontAccessToken: '33e0d25603bbe4b974757f1418d9818b'
              });

              ShopifyBuy.UI.onReady(client).then(function(ui) {
                ui.createComponent('collection', {
                  id: collection.id,
                  node: mountDiv,
                  moneyFormat: '%24%7B%7Bamount%7D%7D',
                  options: shopifyOptions
                });

                // Hide skeleton loader
                if (skeletonDiv) {
                  skeletonDiv.classList.add('hidden');
                }
              });
            }
          });
        };

        document.head.appendChild(script);
      }

      // First-interaction trigger: scroll, pointer, touch, keydown
      function armFirstInteraction() {
        const events = ['scroll', 'pointerdown', 'touchstart', 'keydown'];
        const handleFirstInteraction = function() {
          events.forEach(function(event) {
            document.removeEventListener(event, handleFirstInteraction, { passive: true });
          });
          initializeCollections();
        };

        events.forEach(function(event) {
          document.addEventListener(event, handleFirstInteraction, { passive: true });
        });
      }

      // Arm on page load
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', armFirstInteraction);
      } else {
        armFirstInteraction();
      }
    })();
  </script>

