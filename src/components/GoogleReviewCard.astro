---
/**
 * GoogleReviewCard.astro
 * Reusable Google Review Display Component
 * 
 * Props:
 *   - reviewerName: string (e.g., "Joe Espinoza")
 *   - rating: number (1-5, e.g., 5)
 *   - reviewText: string (review content)
 *   - timeAgo: string (e.g., "16 hours ago")
 *   - photoCount?: number (optional, e.g., 1)
 */

interface Props {
  reviewerName: string;
  rating: number;
  reviewText: string;
  timeAgo: string;
  photoCount?: number;
}

const { reviewerName, rating, reviewText, timeAgo, photoCount } = Astro.props;

// Generate initials from reviewer name
const getInitials = (name: string): string => {
  return name
    .split(' ')
    .map(word => word[0])
    .join('')
    .toUpperCase()
    .substring(0, 2);
};

const initials = getInitials(reviewerName);

// Render star rating
const renderStars = (count: number): string => {
  return '★'.repeat(count) + '☆'.repeat(5 - count);
};
---

<div class="google-review-card">
  <!-- Header: Profile + Name + Rating + Time -->
  <div class="google-review-card__header">
    <div class="google-review-card__avatar">{initials}</div>
    
    <div class="google-review-card__meta">
      <div class="google-review-card__name-row">
        <h3 class="google-review-card__name">{reviewerName}</h3>
      </div>
      <div class="google-review-card__rating-row">
        <span class="google-review-card__stars">{renderStars(rating)}</span>
        <span class="google-review-card__time">{timeAgo}</span>
      </div>
      {photoCount && photoCount > 0 && (
        <div class="google-review-card__photo-count">
          📷 {photoCount} photo{photoCount !== 1 ? 's' : ''}
        </div>
      )}
    </div>
  </div>

  <!-- Review Text -->
  <p class="google-review-card__text">
    {reviewText}
  </p>

  <!-- Google Branding (subtle) -->
  <div class="google-review-card__google-badge">
    <svg class="google-badge-logo" viewBox="0 0 24 24" width="16" height="16">
      <text x="0" y="14" font-size="10" font-weight="bold" fill="currentColor">Google</text>
    </svg>
  </div>
</div>

<style>
  .google-review-card {
    background: #fff;
    border: none;
    border-bottom: 1px solid #e8eaed;
    border-radius: 0;
    padding: 1.5rem 0;
    margin-bottom: 0;
  }

  .google-review-card__header {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    align-items: flex-start;
  }

  .google-review-card__avatar {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #d0d0d0;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.85rem;
    font-family: Roboto, 'Helvetica Neue', sans-serif;
  }

  .google-review-card__meta {
    flex: 1;
  }

  .google-review-card__name-row {
    margin-bottom: 0rem;
  }

  .google-review-card__name {
    font-size: 0.9375rem;
    font-weight: 500;
    color: #3c4043;
    margin: 0;
    font-family: Roboto, 'Helvetica Neue', sans-serif;
    line-height: 1.4;
  }

  .google-review-card__rating-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-top: 0.25rem;
    margin-bottom: 0;
  }

  .google-review-card__stars {
    display: inline-block;
    color: #fcc934;
    font-size: 0.75rem;
    letter-spacing: 1.5px;
    line-height: 1;
  }

  .google-review-card__time {
    font-size: 0.8125rem;
    color: #70777c;
    font-family: Roboto, 'Helvetica Neue', sans-serif;
    margin: 0;
  }

  .google-review-card__photo-count {
    font-size: 0.8125rem;
    color: #70777c;
    margin-top: 0.375rem;
    font-family: Roboto, 'Helvetica Neue', sans-serif;
  }

  .google-review-card__text {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: #3c4043;
    margin: 0.75rem 0 0 0;
    font-family: Roboto, 'Helvetica Neue', sans-serif;
    letter-spacing: 0.2px;
  }

  .google-review-card__google-badge {
    font-size: 0.6875rem;
    color: #70777c;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 0.5rem;
    font-family: Roboto, 'Helvetica Neue', sans-serif;
  }

  .google-badge-logo {
    opacity: 0.7;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .google-review-card {
      padding: 1rem 0;
    }

    .google-review-card__text {
      font-size: 0.9375rem;
    }

    .google-review-card__name {
      font-size: 0.9375rem;
    }
  }
</style>
