---
// Hero.astro - Full-width collage-style hero section
// No React. Pure Astro + CSS.

interface CTAObject {
  text?: string;
  textMobile?: string;
  href?: string;
}

interface Props {
  title?: string;
  titleItalic?: string;
  subtitle?: string;
  primaryCTA?: string | CTAObject;
  primaryCTAUrl?: string;
  secondaryCTA?: string | CTAObject;
  secondaryCTAUrl?: string;
  location?: string;
  heroImage?: string;
  categories?: string[];
}

const {
  title = "Elegance",
  titleItalic = "Redefined.",
  subtitle = "A private, appointment-only boutique specializing in curated bridal gowns, formal evening wear, and bespoke floral event design.",
  primaryCTA = "Book a Private Appointment",
  primaryCTAUrl = "#appointment",
  secondaryCTA = "Visit the Boutique",
  secondaryCTAUrl = "#",
  location = "A Richmond Destination",
  heroImage = "/images/hero.webp",
  categories = ["Bridal", "Formal", "Florals"],
} = Astro.props;

// Normalize CTA values - handle both string and object formats
const getPrimaryCTAText = (): string => {
  if (typeof primaryCTA === 'object' && primaryCTA.text) {
    return primaryCTA.text;
  }
  return typeof primaryCTA === 'string' ? primaryCTA : "Book a Private Appointment";
};

const getPrimaryCTAUrl = (): string => {
  if (typeof primaryCTA === 'object' && primaryCTA.href) {
    return primaryCTA.href;
  }
  return primaryCTAUrl || "#appointment";
};

const getPrimaryCTAMobileText = (): string => {
  if (typeof primaryCTA === 'object' && primaryCTA.textMobile) {
    return primaryCTA.textMobile;
  }
  return getPrimaryCTAText();
};

const getSecondaryCTAText = (): string => {
  if (typeof secondaryCTA === 'object' && secondaryCTA.text) {
    return secondaryCTA.text;
  }
  return typeof secondaryCTA === 'string' ? secondaryCTA : "Visit the Boutique";
};

const getSecondaryCTAUrl = (): string => {
  if (typeof secondaryCTA === 'object' && secondaryCTA.href) {
    return secondaryCTA.href;
  }
  return secondaryCTAUrl || "#";
};

const primaryText = getPrimaryCTAText();
const primaryUrl = getPrimaryCTAUrl();
const primaryMobileText = getPrimaryCTAMobileText();
const secondaryText = getSecondaryCTAText();
const secondaryUrl = getSecondaryCTAUrl();
---

<section class="hero">
  <!-- Single Background Image (Cropped: 1024x847, art-directed composition) -->
  <div class="hero__backdrop">
    <img
      src={heroImage}
      data-editable="image"
      data-prop-src="heroImage"
      alt="Bridal Couture Editorial"
      width="1024"
      height="847"
      decoding="async"
      loading="eager"
      fetchpriority="high"
      class="hero__background-image"
    />
  </div>

  <!-- Gradient Overlay for Text Readability -->
  <div class="hero__overlay"></div>

  <!-- Editorial Text & CTAs -->
  <div class="hero__content">
    <div class="hero__text-block">
      <div class="space-y-12">
        <!-- Accent line + location tag -->
        <div class="accent-line">
          <span class="accent-line-text" data-editable="text" data-prop="location">{location}</span>
        </div>

        <!-- Headline -->
        <h1 class="hero__headline">
          <span data-editable="text" data-prop="title">{title}</span><br />
          <span class="hero__headline-italic" data-editable="text" data-prop="titleItalic">{titleItalic}</span>
        </h1>

        <!-- Subheading -->
        <p class="hero__subheading" data-editable="text" data-prop="subtitle">
          {subtitle}
        </p>

        <!-- Primary & Secondary CTAs -->
        <div class="hero__ctas">
          <a href={primaryUrl} class="button button--primary" data-editable="text" data-prop="primaryCTA">
            {primaryText}
          </a>
          <a href={secondaryUrl} class="button button--outline" data-editable="text" data-prop="secondaryCTA">
            {secondaryText}
          </a>
        </div>

        <!-- Category Badges -->
        {categories && categories.length > 0 && (
          <div class="hero__category-badges">
            {categories.map((category) => {
              const categoryUrls: { [key: string]: string } = {
                "Bridal": "/wedding-dresses-richmond-ky",
                "Formal": "/formal-gowns-richmond-ky",
                "Florals": "/wedding-prom-florist-richmond-ky"
              };
              const url = categoryUrls[category] || "#";
              return (
                <a href={url} class="hero__category-badge">{category}</a>
              );
            })}
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Mobile Sticky CTA -->
  <div class="hero__mobile-cta">
    <a href={primaryUrl} class="button button--primary" data-editable="text" data-prop="primaryCTA">
      {primaryMobileText}
    </a>
  </div>
</section>

<style>
  /* All styles are in /src/styles/global.css for consistency */
</style>
