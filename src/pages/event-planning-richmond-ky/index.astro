---
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/hero/Hero.astro';

// Import optimized WebP assets from src/assets (shared from parent page)
import quinceDecor1 from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/quince-decor-1.webp';
import quinceDecor2 from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/quince-decor-2.webp';
import quinceDecor3 from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/quince-decor-3.webp';
import weddingVenue1 from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/wedding-venue-1.webp';
import weddingVenue2 from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/wedding-venue-2.webp';
import weddingVenue3 from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/wedding-venue-3.webp';
import venueChenault from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/venue-chenault.webp';
import quinceGrandEntrance from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/quinceañera-grand-entrance.webp';
import venueCeremonySetup from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/venue-ceremony-setup.webp';
import venueReceptionSetup from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/venue-reception-setup.webp';
import venueTransformationDetails from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/venue-transformation-details.webp';
import celebrationMoment from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/celebration-moment.webp';
import curatedStylingDetails from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/curated-styling-details.webp';

const metadata = {
  title: "Event Planning Richmond KY | Weddings & Quinceañeras",
  description: "Full-service event planning in Richmond, Kentucky. Wedding coordination and Quinceañera production. Learn about our integrated design approach.",
};

// Generate OG image for social sharing
const og = await getImage({
  src: venueChenault,
  width: 1200,
  height: 630,
  format: "webp",
  fit: "cover",
});
---

<BaseLayout title={metadata.title} description={metadata.description} ogImage={og.src}>
  <!-- ===================================================================
       HERO SECTION
       =================================================================== -->
  <Hero
    title="Event Planning"
    titleItalic="in Richmond, Kentucky"
    subtitle="Full-service wedding, quinceañera, and celebration planning for families across Richmond and Central Kentucky."
    primaryCTA="Book a Planning Consultation"
    primaryCTAUrl="#choose-service"
    secondaryCTA="Explore Our Event Services"
    secondaryCTAUrl="#packages-section"
    location="Weddings & Quinceañeras"
    heroImage={weddingVenue3.src}
  />

  <!-- ===================================================================
       CHOOSE YOUR PLANNING PATH (Navigation Hub)
       =================================================================== -->
  <section id="choose-service" class="choose-service-section">
    <div class="container">
      <div style="display: flex; flex-direction: column; gap: 2.5rem; max-width: 56rem; margin: 0 auto; text-align: center;">
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <h2 style="font-family: var(--font-serif); font-size: clamp(1.75rem, 5vw, 2.75rem); color: var(--color-black); margin: 0;">
            Choose Your Event Planning Service
          </h2>
          <p style="font-size: 1.125rem; color: #999999; font-weight: 300; max-width: 42rem; margin: 0 auto; line-height: 1.6;">
            Select the service that fits your celebration.
          </p>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 2rem;">
          <!-- Wedding Planning Card -->
          <a href="/wedding-planning-richmond-ky/" style="text-decoration: none; display: flex; flex-direction: column; padding: 2rem; background-color: #FDFCFB; border: 2px solid var(--color-gold); border-radius: 8px; transition: transform 300ms ease-out, box-shadow 300ms ease-out;">
            <div style="font-size: 2.5rem; margin-bottom: 1rem;">💍</div>
            <h3 style="font-size: 1.5rem; color: var(--color-black); margin: 0 0 0.75rem 0; font-family: var(--font-serif);">Wedding Planning</h3>
            <p style="font-size: 0.95rem; color: var(--color-charcoal); line-height: 1.6; margin: 0; flex-grow: 1;">
              Month-of coordination to full planning. Design your wedding day with expert guidance on vendor coordination, gown alignment, and decor styling.
            </p>
            <div style="color: var(--color-gold); font-weight: 600; margin-top: 1rem;">Explore Wedding Services →</div>
          </a>

          <!-- Quinceañera Planning Card -->
          <a href="/quinceanera-planning-richmond-ky/" style="text-decoration: none; display: flex; flex-direction: column; padding: 2rem; background-color: #FDFCFB; border: 2px solid var(--color-gold); border-radius: 8px; transition: transform 300ms ease-out, box-shadow 300ms ease-out;">
            <div style="font-size: 2.5rem; margin-bottom: 1rem;">👑</div>
            <h3 style="font-size: 1.5rem; color: var(--color-black); margin: 0 0 0.75rem 0; font-family: var(--font-serif);">Quinceañera Planning</h3>
            <p style="font-size: 0.95rem; color: var(--color-charcoal); line-height: 1.6; margin: 0; flex-grow: 1;">
              XV party planning with cultural expertise. From theme design to court coordination, waltz choreography, and full venue transformation. Bilingual services available.
            </p>
            <div style="color: var(--color-gold); font-weight: 600; margin-top: 1rem;">Explore XV Planning →</div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================================
       AUTHORITY BLOCK (Trust Booster)
       =================================================================== -->
  <section class="authority-block">
    <div class="container">
      <div class="authority-excerpt">
        <p style="text-align: center;">
          Vero's Boutique provides full-service <a href="/wedding-planning-richmond-ky/" style="color: inherit; text-decoration: underline; font-weight: 500;">wedding planning</a> and <a href="/quinceanera-planning-richmond-ky/" style="color: inherit; text-decoration: underline; font-weight: 500;">Quinceañera production</a> in Richmond, Kentucky. 
          From <a href="#integrated-advantage" style="color: inherit; text-decoration: underline; font-weight: 500;">venue design and vendor coordination</a> to couture gown styling and <a href="#integrated-advantage" style="color: inherit; text-decoration: underline; font-weight: 500;">decor production</a>, we manage 
          every detail so families can focus on the celebration instead of the logistics. Serving Madison County, 
          Berea, and Lexington with local expertise and modern, secure booking—because beautiful events start 
          with fast, stress-free planning.
        </p>

        <!-- Quick Navigation CTA Row -->
        <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: var(--space-6); margin-top: var(--space-8);">
          <a href="/wedding-planning-richmond-ky/" style="color: var(--color-navy); font-weight: 500; font-size: var(--text-secondary); text-decoration: none; border-bottom: 2px solid var(--color-gold); padding-bottom: 2px; transition: opacity var(--transition-fast);" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">Wedding Planning Services</a>
          <a href="/quinceanera-planning-richmond-ky/" style="color: var(--color-navy); font-weight: 500; font-size: var(--text-secondary); text-decoration: none; border-bottom: 2px solid var(--color-gold); padding-bottom: 2px; transition: opacity var(--transition-fast);" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">Quinceañera Planning Services</a>
          <a href="#packages-section" style="color: var(--color-navy); font-weight: 500; font-size: var(--text-secondary); text-decoration: none; border-bottom: 2px solid var(--color-gold); padding-bottom: 2px; transition: opacity var(--transition-fast);" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">See Planning Packages</a>
          <a href="#integrated-advantage" style="color: var(--color-navy); font-weight: 500; font-size: var(--text-secondary); text-decoration: none; border-bottom: 2px solid var(--color-gold); padding-bottom: 2px; transition: opacity var(--transition-fast);" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">Design Philosophy</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================================
       INTEGRATED ADVANTAGE (Differentiator)
       =================================================================== -->
  <section id="integrated-advantage" class="advantage-section">
    <div class="container">
      <h2 style="text-align: center;">Where Couture Meets Production Design</h2>
      
      <p class="advantage-excerpt" style="text-align: center;">
        Most event planners and florists work separately. You pick a gown, then search for florals. 
        You coordinate decor details, then realize they don't match your dress. We eliminate that gap. 
        At Vero's Boutique, your selected gown becomes the design anchor. We build florals, linens, lighting, 
        and styling around it, ensuring every element complements your couture—creating the cohesive, 
        editorial-quality aesthetic that independent planners often can't deliver.
      </p>

      <div class="advantage-points">
        <div class="advantage-point" style="text-align: center;">
          <h4>🎯 Gown-Centric Design</h4>
          <p style="text-align: center;">Your dress drives the entire aesthetic, not the other way around.</p>
        </div>
        <div class="advantage-point" style="text-align: center;">
          <h4>✨ Unified Execution</h4>
          <p style="text-align: center;">One expert team handles gown selection, florals, decor, and styling—no coordination gaps.</p>
        </div>
        <div class="advantage-point" style="text-align: center;">
          <h4>🏻 Editorial-Quality Results</h4>
          <p style="text-align: center;">Every detail is curated with luxury boutique expertise, not generic templates.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================================
       PRICING PACKAGES SECTION
       =================================================================== -->
  <section id="packages-section" class="pricing-section">
    <div class="container">
      <h2 style="text-align: center;">Event Planning Packages</h2>
      
      <p class="pricing-intro" style="text-align: center;">
        Transparent planning based on scope and vision. Our flexible tiers adapt to your celebration's 
        needs whether you're planning a wedding or Quinceañera. Final investment varies with guest count, venue, seasonality, installation complexity, and travel. 
        Request a custom proposal after consultation.
      </p>

      <div class="pricing-cards">
        <div class="pricing-card">
          <h3>Essential Management</h3>
          <p class="pricing-card__description">Day-of Coordination & Vendor Oversight</p>
          <ul class="pricing-card__features">
            <li>Final 30-day timeline & checklist</li>
            <li>Vendor confirmations & contact sheet</li>
            <li>Day-of ceremony & reception oversight</li>
            <li>Real-time problem solving</li>
            <li>Setup & breakdown coordination</li>
          </ul>
        </div>

        <div class="pricing-card">
          <h3>Signature Series</h3>
          <p class="pricing-card__description">Partial Planning + Decor Styling</p>
          <ul class="pricing-card__features">
            <li>Vendor recommendations & confirmations</li>
            <li>Design concept & color palette</li>
            <li>Gown selection guidance</li>
            <li>Floral design coordination</li>
            <li>Decor & styling curation</li>
            <li>Day-of coordination</li>
          </ul>
        </div>

        <div class="pricing-card">
          <h3>Royal Production</h3>
          <p class="pricing-card__description">Full Planning + Custom Decor & Choreography</p>
          <ul class="pricing-card__features">
            <li>Complete event planning from concept</li>
            <li>Venue selection & contract negotiation</li>
            <li>Full vendor management</li>
            <li>Custom decor & floral design</li>
            <li>Waltz/choreography guidance (XV)</li>
            <li>Gown & bridal party styling</li>
            <li>Setup & day-of execution</li>
            <li>Post-event follow-up</li>
          </ul>
        </div>
      </div>

      <p class="pricing-note" style="text-align: center;">
        <strong>What Affects Final Investment:</strong> Guest count, venue selection, decor complexity, 
        seasonal availability, custom installations, and travel distance to venue. Contact us for a transparent 
        consultation and custom proposal tailored to your celebration.
      </p>
    </div>
  </section>

  <!-- ===================================================================
       GALLERY SECTION (Trust & Visual Proof)
       =================================================================== -->
  <section class="gallery-section">
    <div class="container">
      <h2 style="text-align: center;">Real Richmond & Madison County Events</h2>

      <p class="section-intro" style="text-align: center;">
        From intimate Berea celebrations to elaborate Madison County events, these transformations 
        showcase what full-service planning looks like.
      </p>

      <div class="portfolio-gallery">
        <!-- LARGE PORTFOLIO ITEM 1: venue-chenault.webp -->
        <div class="gallery-item-large">
          <img
            src={venueChenault.src}
            alt="Chenault Vineyards outdoor wedding elegance in Richmond KY"
            width={1600}
            height={1200}
            loading="lazy"
            decoding="async"
            class="gallery-image-large"
          />
          <p class="gallery-label-large">Event Venue: Outdoor Elegance</p>
        </div>

        <div class="gallery-item-small">
          <img
            src={venueCeremonySetup.src}
            alt="Wedding ceremony setup Madison County Kentucky"
            width={1000}
            height={800}
            loading="lazy"
            decoding="async"
            class="gallery-image-small"
          />
          <p class="gallery-label-small">Venue Ceremony Setup</p>
        </div>

        <div class="gallery-item-small">
          <img
            src={venueReceptionSetup.src}
            alt="Wedding reception setup Madison County Kentucky"
            width={1000}
            height={800}
            loading="lazy"
            decoding="async"
            class="gallery-image-small"
          />
          <p class="gallery-label-small">Venue Reception Setup</p>
        </div>

        <div class="gallery-item-small">
          <img
            src={venueTransformationDetails.src}
            alt="Event venue decor transformation Richmond Kentucky - elegant detail design"
            width={1000}
            height={800}
            loading="lazy"
            decoding="async"
            class="gallery-image-small"
          />
          <p class="gallery-label-small">Venue Transformation Details</p>
        </div>

        <div class="gallery-item-small">
          <img
            src={celebrationMoment.src}
            alt="Grand moment at event celebration"
            width={1000}
            height={800}
            loading="lazy"
            decoding="async"
            class="gallery-image-small"
          />
          <p class="gallery-label-small">Celebration Moment</p>
        </div>

        <div class="gallery-item-small">
          <img
            src={curatedStylingDetails.src}
            alt="Event detail styling and design"
            width={1000}
            height={800}
            loading="lazy"
            decoding="async"
            class="gallery-image-small"
          />
          <p class="gallery-label-small">Curated Styling Details</p>
        </div>

        <div class="gallery-item-large gallery-item-last">
          <img
            src={quinceGrandEntrance.src}
            alt="Quinceañera grand entrance celebration in Richmond Kentucky"
            width={1600}
            height={1200}
            loading="lazy"
            decoding="async"
            class="gallery-image-large"
          />
          <p class="gallery-label-large">XV Grand Entrance: Unforgettable Moment</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================================
       FAQ SECTION (Shared FAQs Only)
       =================================================================== -->
  <section id="faq" class="faq-section">
    <div class="container">
      <h2 style="text-align: center;">Frequently Asked Questions About Event Planning</h2>

      <div class="faq-grid">
        <div class="faq-item">
          <h3>How much does event planning cost?</h3>
          <p>
            Event planning investment varies widely based on scope, guest count, venue, decor complexity, 
            installation requirements, and timeline. Rather than one-size pricing, Vero's Boutique customizes 
            proposals to match your vision and budget. Our three planning tiers (Essential Management, Signature 
            Series, and Royal Production) provide flexibility, from coordination-only to full concept-to-execution 
            planning. Schedule a consultation so we can discuss your celebration and provide a transparent, 
            custom quote tailored to your needs.
          </p>
        </div>

        <div class="faq-item">
          <h3>Can I bundle my gown and planning services?</h3>
          <p>
            Absolutely. One of our key advantages is integrated service—gown selection, event planning, 
            and floral design in one place. Bundle your wedding dress or Quinceañera gown with planning 
            services for cohesive aesthetic alignment and simplified coordination. Ask about package 
            options during your consultation.
          </p>
        </div>

        <div class="faq-item">
          <h3>Do you provide decor setup and teardown?</h3>
          <p>
            Yes. Full decor setup and teardown are included in our Royal Production and Signature Series 
            packages. We manage all installations, from floral arrangements to linens and lighting. 
            Essential Management coordinates your vendors but doesn't include hands-on setup. Discuss 
            your specific needs during consultation.
          </p>
        </div>

        <div class="faq-item">
          <h3>What areas do you serve (Richmond, Berea, Lexington)?</h3>
          <p>
            Vero's Boutique serves Richmond, Berea, Lexington, and surrounding Central Kentucky communities 
            in Madison County and beyond. We coordinate weddings and Quinceañeras within a 45-minute drive 
            of Richmond. For destinations beyond this radius, we offer planning consultation with travel 
            fees. Contact us with your venue location.
          </p>
        </div>

        <div class="faq-item">
          <h3>Do you offer corporate or gala event production?</h3>
          <p>
            Yes, Vero's Boutique customizes planning services for corporate galas, milestone celebrations, 
            formal fundraisers, and private events. We bring the same design expertise and vendor coordination 
            to business events. Contact us for corporate event inquiries and a custom proposal.
          </p>
        </div>

        <div class="faq-item">
          <h3>Can you work with our existing wedding or event vendors?</h3>
          <p>
            Yes. We coordinate seamlessly with your selected vendors. Bring your florist, venue, or caterer—we manage vendor communication, timing, and design alignment. If you need recommendations, we have trusted local partners ready to collaborate.
          </p>
        </div>
      </div>

      <div class="faq-cta" style="text-align: center;">
        <p style="text-align: center;">Need service-specific details?</p>
        <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem; margin-top: 1rem;">
          <a href="/wedding-planning-richmond-ky/" class="button button--outline">Wedding Planning FAQs</a>
          <a href="/quinceanera-planning-richmond-ky/" class="button button--outline">Quinceañera Planning FAQs</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================================
       FINAL CTA SECTION
       =================================================================== -->
  <section class="final-cta-section">
    <div class="container" style="text-align: center;">
      <h2 style="text-align: center;">Ready to Plan Your Event?</h2>
      <p style="text-align: center;">
        Choose your service and let's start designing your celebration. From concept to execution, 
        we handle every detail so you can focus on the joy of your event.
      </p>
      <div style="text-align: center; display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 2rem;">
        <a href="/wedding-planning-richmond-ky/" class="button button--primary">
          Plan Your Wedding
        </a>
        <a href="/quinceanera-planning-richmond-ky/" class="button button--primary">
          Plan Your XV
        </a>
      </div>
    </div>
  </section>

  <!-- ===================================================================
       GEO-EXPANSION LINE
       =================================================================== -->
  <section class="geo-section">
    <div class="container">
      <p class="geo-text" style="text-align: center;">
        <strong>Serving</strong> Richmond, Berea, Lexington, and surrounding Central Kentucky communities 
        with full-service wedding and Quinceañera planning, coordination, and design.
      </p>
    </div>
  </section>
</BaseLayout>

<!-- ===================================================================
     STRUCTURED DATA / SCHEMA MARKUP
     =================================================================== -->

