<style>
  /* ===================================================================
     HERO SECTION STYLES
     =================================================================== */
  
  .hero-events {
    position: relative;
    height: clamp(20rem, 75vw, 32rem);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--color-ivory);
    margin-bottom: var(--space-16);
  }

  .hero-events__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-events__video {
      animation: none;
    }
  }

  .hero-events__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(13, 27, 42, 0.3), rgba(13, 27, 42, 0.5));
    z-index: 1;
  }

  .hero-events__content {
