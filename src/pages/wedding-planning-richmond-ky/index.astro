<style>
  /* ===================================================================
     HERO SECTION STYLES
     =================================================================== */
  
  .hero-events {
    position: relative;
    height: clamp(20rem, 75vw, 32rem);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--color-ivory);
    margin-bottom: var(--space-16);
  }

  .hero-events__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-events__video {
      animation: none;
    }
  }

  .hero-events__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(13, 27, 42, 0.3), rgba(13, 27, 42, 0.5));
    z-index: 1;
  }

  .hero-events__content {
    position: relative;
    z-index: 2;
    max-width: 56rem;
    padding: var(--space-8);
    text-align: center;
    color: white;
  }

  .hero-events__h1 {
    margin-bottom: var(--space-4);
  }

  .hero-events__h1-sub {
    font-style: italic;
    font-weight: 400;
  }

  .hero-events__subheading {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: var(--lh-loose);
    max-width: 50rem;
    margin: var(--space-4) auto var(--space-8);
  }

  .hero-events__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    justify-content: center;
    margin-top: var(--space-8);
  }

  /* ===================================================================
     WEDDING COORDINATION SECTION
     =================================================================== */

  .wedding-coordination-section {
    padding: var(--space-12) var(--space-6);
    background-color: var(--color-ivory);
    margin-bottom: var(--space-16);
  }

  .wedding-coordination-section h2 {
    text-align: center;
  }

  .section-intro {
    font-size: var(--text-body);
    line-height: var(--lh-loose);
    max-width: 90ch;
    margin: var(--space-6) auto var(--space-12);
    color: var(--color-charcoal);
    text-align: center;
  }

  /* Coordination services */
  .coordination-services {
    margin: var(--space-12) 0;
  }

  .coordination-services h3 {
    text-align: center;
    margin-bottom: var(--space-8);
    color: var(--color-navy);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  .service-item {
    padding: var(--space-8);
    background-color: white;
    border-radius: 8px;
    border-top: 4px solid var(--color-gold);
  }

  .service-icon {
    font-size: 2rem;
    margin-bottom: var(--space-4);
  }

  .service-item h4 {
    color: var(--color-navy);
    margin-bottom: var(--space-6);
  }

  .service-list {
    list-style: none;
    padding: 0;
  }

  .service-list li {
    padding: var(--space-2) 0;
    padding-left: var(--space-6);
    position: relative;
    font-size: var(--text-secondary);
    color: var(--color-gray-medium);
    line-height: var(--lh-relaxed);
  }

  .service-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-gold);
