---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/hero/Hero.astro';
import GoogleReviewCard from '../../components/GoogleReviewCard.astro';

const metadata = {
  title: "Wedding Dresses Richmond KY | Bridal Gowns & Fittings | Vero's Boutique",
  description: "Curated bridal gowns and personalized fittings in Richmond, Kentucky. Expert bridal stylists. Book your private 90-minute appointment today.",
};
---

<BaseLayout title={metadata.title} description={metadata.description} robots="index, follow">
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: HERO -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <Hero
    title="Find Your Perfect"
    titleItalic="Bridal Gown"
    subtitle="Expert bridal styling. Curated selection. Your dream dress awaits."
    primaryCTA="Explore Bridal Collections"
    primaryCTAUrl="#bridal-collections"
    secondaryCTA="Book a Bridal Fitting"
    secondaryCTAUrl="/book-an-appointment/?service=bridal-fitting"
    location="Hand-Curated Wedding Dresses"
    categories={["Bridal", "Formal", "Florals"]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: BRIDAL BOUTIQUE AUTHORITY -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="boutique-intro">
    <div class="boutique-intro__container">
      <h2 class="section-title section-title-lg boutique-intro__heading">A Bridal Partner, Not Just a Dress Shop</h2>
      
      <p class="boutique-intro__text">
        Vero's Boutique is more than a place to find a dress—it's a bridal experience. Located in downtown Richmond, Kentucky, we specialize in wedding gowns hand-selected for brides who deserve personalized attention. Whether you're from Richmond, Lexington, Nicholasville, or Winchester, we offer what big-box retailers can't: expert bridal consultants, a curated collection, and a private, pressure-free environment where your vision becomes reality.
      </p>

      <p class="boutique-intro__text">
        Our stylists specialize in wedding dresses. We listen to your vision, understand your comfort level, and present options that flatter your body type and personality. More than that—we coordinate your gown selection with your entire wedding aesthetic, ensuring your dress, florals, venue, and ceremony details work together seamlessly.
      </p>

      <a href="/book-an-appointment/?service=bridal-fitting" class="button button--primary">Book Your 90-Minute Bridal Fitting</a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 3: BRIDAL GOWN COLLECTIONS (SHOPIFY) -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="collection-section" id="bridal-collections">
    <div class="collection-section__container">
      <h2 class="section-title section-title-lg collection-section__title">Bridal Gowns & Wedding Dresses</h2>
      <p class="section-subtitle collection-section__description">
        Hand-curated wedding dresses for Richmond & Madison County brides. From classic elegance to modern drama—browse our collections.
      </p>

      <!-- Skeleton Loader (8 cards) -->
      <div id="skeleton-loader-bridal-gowns" class="skeleton-loader">
        <div class="skeleton-card"><div class="skeleton-img"></div></div>
        <div class="skeleton-card"><div class="skeleton-img"></div></div>
        <div class="skeleton-card"><div class="skeleton-img"></div></div>
        <div class="skeleton-card"><div class="skeleton-img"></div></div>
        <div class="skeleton-card"><div class="skeleton-img"></div></div>
        <div class="skeleton-card"><div class="skeleton-img"></div></div>
        <div class="skeleton-card"><div class="skeleton-img"></div></div>
        <div class="skeleton-card"><div class="skeleton-img"></div></div>
      </div>

      <!-- Shopify Mount Point -->
      <div id="collection-component-bridal-gowns" class="collection-mount"></div>

      <!-- Static Links (SEO) -->
      <div class="collection-links">
        <a href="/wedding-dresses-richmond-ky/">View Full Bridal Collection</a>
        <a href="/book-an-appointment/?service=bridal-fitting">Book a Fitting</a>
        <a href="/reviews/">Read Customer Reviews</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: CTA BLOCK #1 - BENEFITS -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="cta-block cta-block--light">
    <div class="cta-block__container">
      <h2 class="cta-block__title">Why Choose Vero's Boutique for Your Bridal Gown?</h2>
      <div class="cta-block__grid">
        <div class="cta-block__item">
          <h3 class="cta-block__item-title">Expert Bridal Consultants</h3>
          <p class="cta-block__item-text">Our stylists specialize in wedding dresses. We listen to your vision, assess your comfort level, and present options that flatter your body type and personality. No rushing. No judgment. Just you, your gown, and expert guidance.</p>
        </div>
        <div class="cta-block__item">
          <h3 class="cta-block__item-title">Curated Collections</h3>
          <p class="cta-block__item-text">We hand-select every piece in our boutique. No overwhelming racks. Every dress reflects current trends, timeless elegance, and quality craftsmanship. You're shopping from a thoughtfully edited selection, not generic inventory.</p>
        </div>
        <div class="cta-block__item">
          <h3 class="cta-block__item-title">Integrated Wedding Services</h3>
          <p class="cta-block__item-text">Need wedding planning or ceremony florals? We coordinate your gown selection with venue design, floral aesthetics, and day-of coordination. Your wedding looks cohesive, not fragmented.</p>
        </div>
      </div>
      <div class="button-row">
        <a href="/book-an-appointment/?service=bridal-fitting" class="button button--primary button--large">Book a Fitting Today</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 5: THE BRIDAL FITTING EXPERIENCE -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bridal-experience">
    <div class="bridal-experience__container">
      <h2 class="section-title section-title-lg section-heading-centered">The Vero's Bridal Experience</h2>

      <div class="experience-content">
        <div class="experience-subsection">
          <h3>What to Expect</h3>
          <p>Schedule a 90-minute private appointment—one bride, expert engagement. You'll work directly with our experienced bridal stylists in our Richmond boutique, where we focus entirely on finding the dress that makes you feel like yourself.</p>
        </div>

        <div class="experience-subsection">
          <h3>Preparation</h3>
          <p>Bring photos or ideas of styles you love, plus any notes about your wedding vision. Wear nude undergarments and shoes with a similar heel height to what you'll wear on your wedding day. This helps us assess the true fit and look of each gown.</p>
        </div>

        <div class="experience-subsection">
          <h3>The Process</h3>
          <p>First, we'll chat about your vision, wedding date, and what you're looking for. Then we'll present hand-selected options from our curated collection. Try on dresses that match your style and comfort level. Our team provides honest styling feedback, helping you see how each gown makes you feel. Finally, we discuss alterations, timeline, and next steps.</p>
        </div>

        <div class="experience-subsection">
          <h3>After Your Fitting</h3>
          <p>Once you've chosen your gown, we'll guide you through alterations. Our expert team handles hemming, taking in/letting out, and custom adjustments. We provide comprehensive care instructions and preservation guidance to ensure your dress looks perfect on your wedding day and beyond.</p>
        </div>

        <div class="experience-subsection">
          <h3>Frequently Asked Questions</h3>
          <ul class="experience-faq">
            <li><strong>Do you take walk-ins?</strong> Yes, when availability allows. We recommend booking ahead to guarantee your ideal time slot.</li>
            <li><strong>Can I bring bridesmaids?</strong> Absolutely. We encourage bringing your trusted bridal party for a fun, supportive fitting experience.</li>
            <li><strong>Do you offer alterations?</strong> Yes, our expert in-house team handles all alterations with care and precision.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 6: BRIDAL ACCESSORIES & CEREMONY TRADITIONS -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="collection-section" id="accessories">
    <div class="collection-section__container">
      <h2 class="section-title section-title-lg collection-section__title">Complete Your Bridal Look — Accessories & Ceremony Traditions</h2>
      <p class="section-subtitle collection-section__description">
        A bridal gown is just the beginning. We have everything from veils and jewelry to ceremonial pieces—including the traditional wedding lasso (rosario de boda). Finish your look with pieces that honor your style and traditions.
      </p>

      <!-- What We Carry Section -->
      <div class="accessories-detail-box accessories-detail-box--gold">
        <h3>What We Carry</h3>
        <ul>
          <li>Veils, headpieces & hair accessories</li>
          <li>Bridal jewelry (earrings, necklaces, bracelets, anklets)</li>
          <li>Ring pillows (classic & custom options)</li>
          <li>Wedding lasso / lazo de boda / rosario de boda (traditional ceremony piece)</li>
          <li>Ceremony accessories (handkerchiefs, garters, finishing touches)</li>
          <li>Undergarments & shaping for the perfect fit</li>
        </ul>
      </div>

      <!-- The Tradition Behind It Section -->
      <div class="accessories-detail-box accessories-detail-box--charcoal">
        <h3>The Tradition Behind It</h3>
        <p>
          For many Latina and Latinx brides, the lasso (lazo de boda or rosario de boda) is a sacred part of the ceremony. It's placed around the couple during the vows as a symbol of unity and blessing. We source quality pieces that honor this tradition and can guide you in styling it to match your bridal aesthetic. Whether you're incorporating cultural traditions or seeking ceremony details that feel personal, we respect every bride's journey.
        </p>
      </div>

      <!-- Skeleton Loader (4 cards) -->
      <div id="skeleton-loader-accessories" class="skeleton-loader">
        <div class="skeleton-card"><div class="skeleton-img"></div></div>
        <div class="skeleton-card"><div class="skeleton-img"></div></div>
        <div class="skeleton-card"><div class="skeleton-img"></div></div>
        <div class="skeleton-card"><div class="skeleton-img"></div></div>
      </div>

      <!-- Shopify Mount Point -->
      <div id="collection-component-accessories" class="collection-mount"></div>

      <!-- Static Links (SEO) -->
      <div class="collection-links">
        <a href="/wedding-dresses-richmond-ky/#accessories">View All Accessories</a>
        <a href="/book-an-appointment/?service=bridal-fitting">Book an Accessory Consultation</a>
        <a href="/reviews/">Read Bridal Reviews</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 7: INTEGRATED WEDDING SERVICES -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="integrated-services">
    <div class="integrated-services__container">
      <h2 class="section-title section-title-lg section-heading-centered">Plan Your Entire Wedding With Vero's</h2>
      <p class="section-intro">
        Your bridal gown doesn't stand alone. Once you've found your dress, our integrated services help you design every other detail—from florals to coordination to venue transformation.
      </p>

      <!-- Services Grid -->
      <div class="links-grid">
        <a href="/wedding-planning-richmond-ky/" class="link-card">
          <span class="link-icon">🎨</span>
          <span class="link-text">
            <strong>Wedding Planning & Coordination</strong>
            Month-of coordination to full planning. Design your wedding day with expert guidance on vendor coordination, gown alignment, and decor styling.
          </span>
        </a>
        <a href="/wedding-prom-florist-richmond-ky/" class="link-card">
          <span class="link-icon">🌸</span>
          <span class="link-text">
            <strong>Wedding Florals & Ceremony Design</strong>
            Bridal bouquets & ceremony florals coordinated with your gown aesthetic. Same-day arrangements available.
          </span>
        </a>
        <a href="/event-planning-richmond-ky/" class="link-card">
          <span class="link-icon">💒</span>
          <span class="link-text">
            <strong>Ceremony & Venue Coordination</strong>
            Full venue transformation, ceremony setup, and day-of logistics. Your vision brought to life.
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 8: CTA BLOCK #2 - BOOKING EMPHASIS -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="cta-block cta-block--dark">
    <div class="cta-block__container">
      <h2 class="cta-block__title">Ready to Find Your Dream Wedding Dress?</h2>
      <p class="section-intro">
        Book a private 90-minute fitting at our Richmond boutique. Our bridal stylists will help you discover the gown that makes you feel like yourself on your wedding day.
      </p>
      <div class="button-row">
        <a href="/book-an-appointment/?service=bridal-fitting" class="button button--primary button--large">Book a Bridal Fitting</a>
        <a href="#accessories" class="button button--outline button--large">Shop Wedding Accessories</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 9: SOCIAL PROOF / REVIEWS -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="reviews-section">
    <div class="reviews-section__container">
      <h2 class="section-title section-title-lg section-heading-small-margin">Trusted by Richmond Brides</h2>
      <p class="section-intro">
        See what brides in Richmond, Lexington, and Central Kentucky say about their Vero's Boutique experience.
      </p>

      <div class="reviews-grid">
        <GoogleReviewCard
          reviewerName="Sarah M."
          rating={5}
          timeAgo="2 weeks ago"
          reviewText="The experience was incredible. Vero's team understood exactly what I was looking for and helped me find the dress I didn't even know I needed. From consultation to alterations, everything was handled with such care and expertise."
        />
        <GoogleReviewCard
          reviewerName="Jessica L."
          rating={5}
          timeAgo="1 month ago"
          reviewText="They made me feel so comfortable and never pressured me. The personal styling made all the difference. I found my dream dress! Can't recommend Vero's highly enough for any bride-to-be."
        />
        <GoogleReviewCard
          reviewerName="Maria D."
          rating={5}
          timeAgo="6 weeks ago"
          reviewText="From the fitting to alterations, every step was handled with care. This is not your typical bridal shop—it's an experience. The team truly understands what brides need and delivers on it."
        />
      </div>

      <div class="centered-content">
        <a href="/reviews/" class="button button--outline">See More Bridal Reviews</a>
      </div>
    </div>
  </section>

  <!-- Shopify Buy Button Scripts -->
  <script>
