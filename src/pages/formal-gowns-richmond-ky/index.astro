          skeletonId: 'skeleton-loader-arrivals',
          guard: '__shopifyNewArrivalsInitialized'
        }
      ];

      // Shopify options object (shared across all collections)
      const shopifyOptions = {
        product: {
          styles: {
            product: {
              "@media (max-width: 600px)": {
                "max-width": "calc(50% - 10px)",
                "margin-left": "10px",
