---
// src/pages/index.astro
// Main homepage for Vero's Boutique
// Lighthouse-optimized: Text as LCP, lazy-loaded images, no CLS

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/hero/Hero.astro';
import ReviewWidget from '../components/ReviewWidget.astro';

// Import hero images for secondary services
import weddingVenue3 from '../assets/event-planning-quinceaneras-weddings-richmond-ky/wedding-venue-3.webp';
import flowerHeroImage from '../assets/hero/wedding-prom-florist-richmond-ky/wedding-prom-florist-richmond-ky.hero.webp';

const metadata = {
  title: "Vero's Boutique | Beautiful Gowns for Every Budget",
  description: "Beautiful designer gowns for every budget. Expert bridal, quinceañera, and prom styling. Flexible payment plans available. Private appointments in Richmond, Kentucky.",
};

// Hero content — structured so CloudCannon data-prop bindings in Hero.astro are data-backed
const heroData = {
  title: "Elegance,",
  titleItalic: "Redefined.",
  subtitle: "Expert gowns and styling for every price point. Weddings. Quinceañeras. Prom. Florals. Every girl deserves to feel beautiful and heard.",
  primaryCTA: "Book a Private Appointment",
  primaryCTAUrl: "#appointment",
  secondaryCTA: "Visit the Boutique",
  secondaryCTAUrl: "/visit-the-boutique",
  location: "A Richmond KY Destination Boutique",
  heroImage: "/images/hero.webp",
  categories: ["Bridal", "Formal", "Florals"],
};

// Check for form submission success
const submitted = Astro.url.searchParams.get("submitted");
---

<BaseLayout title={metadata.title} description={metadata.description}>
  <!-- Early offer banner now displays sitewide via BaseLayout.astro -->

  {submitted === "success" && (
    <div class="submission-success-banner">
      <p class="submission-success-banner__text">
        ✅ Success! We've received your request.
      </p>
    </div>
  )}

  <!-- Hero Section -->
  <Hero {...heroData} />

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: VISUAL DISCOVERY - PRIMARY SHOPPING CATEGORIES -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="visual-discovery">
    <div class="visual-discovery__container">
      <!-- Pill Navigation -->
      <nav class="discovery-pills">
        <a href="/formal-gowns-richmond-ky/prom-2026/" class="pill">Prom 2026</a>
        <a href="/formal-gowns-richmond-ky/gala-evening/" class="pill">Gala & Evening</a>
        <a href="/wedding-dresses-richmond-ky/" class="pill">Wedding Gowns</a>
        <a href="/quinceanera-dresses-richmond-ky/" class="pill">Quinceañera</a>
        <a href="/formal-gowns-richmond-ky/new-arrivals/" class="pill">New Arrivals</a>
      </nav>

      <!-- Card Grid -->
      <div class="discovery-grid">
        <!-- Card 1: Prom 2026 -->
        <a href="/formal-gowns-richmond-ky/prom-2026/" class="visual-card">
          <div class="visual-card__image-wrapper">
            <img
              src="/images/formal-gowns-hero.webp"
              alt="Prom dresses and formal gowns at Vero's Boutique Richmond Kentucky"
              width="600"
              height="450"
              loading="lazy"
              decoding="async"
            />
            <div class="visual-card__overlay"></div>
          </div>
          <div class="visual-card__content">
            <h3 class="visual-card__title">Prom 2026</h3>
            <p class="visual-card__cta">Shop Prom 2026 →</p>
          </div>
        </a>

        <!-- Card 2: Gala & Evening Wear -->
        <a href="/formal-gowns-richmond-ky/gala-evening/" class="visual-card">
          <div class="visual-card__image-wrapper">
            <img
              src="/images/formal-gowns-hero.webp"
              alt="Elegant gala and evening wear collection at Vero's Boutique"
              width="600"
              height="450"
              loading="lazy"
              decoding="async"
            />
            <div class="visual-card__overlay"></div>
          </div>
          <div class="visual-card__content">
            <h3 class="visual-card__title">Gala & Evening Wear</h3>
            <p class="visual-card__cta">Shop Evening Wear →</p>
          </div>
        </a>

        <!-- Card 3: Wedding Gowns -->
        <a href="/wedding-dresses-richmond-ky/" class="visual-card">
          <div class="visual-card__image-wrapper">
            <img
              src="/images/hero.webp"
              alt="Wedding dresses and bridal gowns at Vero's Boutique"
              width="600"
              height="450"
              loading="lazy"
              decoding="async"
            />
            <div class="visual-card__overlay"></div>
          </div>
          <div class="visual-card__content">
            <h3 class="visual-card__title">Wedding Gowns</h3>
            <p class="visual-card__cta">Find Your Dress →</p>
          </div>
        </a>

        <!-- Card 4: Quinceañera Dresses -->
        <a href="/quinceanera-dresses-richmond-ky/" class="visual-card">
          <div class="visual-card__image-wrapper">
            <img
              src="/images/quinceanera-dresses-richmond-ky/hero-quinceanera-court-styling.webp"
              alt="Quinceañera XV dresses and court styling at Vero's Boutique"
              width="600"
              height="450"
              loading="lazy"
              decoding="async"
            />
            <div class="visual-card__overlay"></div>
          </div>
          <div class="visual-card__content">
            <h3 class="visual-card__title">Quinceañera Dresses</h3>
            <p class="visual-card__cta">Explore XV Styles →</p>
          </div>
        </a>

        <!-- Card 5: New Arrivals -->
        <a href="/formal-gowns-richmond-ky/new-arrivals/" class="visual-card">
          <div class="visual-card__image-wrapper">
            <img
              src="/images/hero.webp"
              alt="New arrival dresses at Vero's Boutique Richmond Kentucky"
              width="600"
              height="450"
              loading="lazy"
              decoding="async"
            />
            <div class="visual-card__overlay"></div>
          </div>
          <div class="visual-card__content">
            <h3 class="visual-card__title">New Arrivals</h3>
            <p class="visual-card__cta">See What's New →</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: BOUTIQUE AUTHORITY INTRO -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="boutique-intro">
    <div class="boutique-intro__container">
      <h2 class="section-title section-title-lg boutique-intro__heading">Every Girl Deserves to Celebrate Her Moment</h2>
      
      <p class="boutique-intro__text">
        At Vero's Boutique, we believe beautiful gowns shouldn't come with complicated prices or pressure. We specialize in bridal gowns, quinceañera dresses, prom and formal wear, florals, and complete event planning. Located in downtown Richmond, Kentucky, we curate stunning collections, offer expert styling, and work with families to make your celebration possible. Flexible payment options and personalized attention are part of who we are.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2B: SECONDARY SERVICES - EVENT PLANNING & FLORALS -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="secondary-services">
    <div class="secondary-services__container">
      <h3 class="section-title section-title-md secondary-services__title">Complete Celebration Services</h3>
      
      <div class="secondary-services__grid">
        <!-- Event Planning -->
        <a href="/event-planning-richmond-ky/" class="secondary-card">
          <div class="secondary-card__image-wrapper">
            <img
              src={weddingVenue3.src}
              alt="Event planning and wedding venue coordination at Vero's Boutique Richmond Kentucky"
              width="600"
              height="350"
              loading="lazy"
              decoding="async"
            />
            <div class="secondary-card__overlay"></div>
          </div>
          <div class="secondary-card__content">
            <h4 class="secondary-card__title">Event Planning</h4>
            <p class="secondary-card__cta">Explore Planning →</p>
          </div>
        </a>

        <!-- Florals -->
        <a href="/wedding-prom-florist-richmond-ky/" class="secondary-card">
          <div class="secondary-card__image-wrapper">
            <img
              src={flowerHeroImage.src}
              alt="Wedding florals and prom corsages at Vero's Boutique Richmond Kentucky"
              width="600"
              height="350"
              loading="lazy"
              decoding="async"
            />
            <div class="secondary-card__overlay"></div>
          </div>
          <div class="secondary-card__content">
            <h4 class="secondary-card__title">Event Florals</h4>
            <p class="secondary-card__cta">View Designs →</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 3: CORE SERVICE CATEGORIES (ARCHIVED - REPLACED BY VISUAL DISCOVERY) -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- This section has been replaced by the Visual Discovery grid above -->
  <!-- Keeping structure for reference but removing from render -->

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: THE VERO'S APPROACH -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="approach-section">
    <div class="approach-section__container">
      <h2 class="section-title section-title-lg approach-section__title">How We Serve You</h2>

      <div class="approach-section__grid">
        <div class="approach-item">
          <h3>Private Appointments</h3>
          <p>One stylist, one client. Your dedicated time. We listen to you, never pressure you. Someone who understands your vision and your budget.</p>
        </div>

        <div class="approach-item">
          <h3>Expert Curation</h3>
          <p>We hand-select every piece with you in mind. No overwhelming racks. Quality, style, AND prices that work for real families.</p>
        </div>

        <div class="approach-item">
          <h3>Integrated Services</h3>
          <p>Dress, florals, venue design—coordinated seamlessly. Your wedding or event looks cohesive because every service works together.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: SOCIAL PROOF - TRUSTED BY RICHMOND FAMILIES -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <ReviewWidget title="Trusted by Richmond Families" />

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 5: FINAL CTA - APPOINTMENT BOOKING -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section id="appointment" class="final-cta">
    <div class="final-cta__container">
      <h2 class="final-cta__heading">Ready to Begin?</h2>
      <p class="final-cta__subheading">
        Schedule a private fitting with our stylists. Discover your dress. Embrace your moment.
      </p>
      <div class="button-row">
        <a href="/book-an-appointment/" class="button button--primary button--large">
          Book a Private Appointment
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════════════════ */
  /* HOMEPAGE SECTIONS - Scoped Styling */
  /* ═══════════════════════════════════════════════════════════════ */

  /* SECTION 1: Boutique Authority Intro */
  .boutique-intro {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-ivory);
  }

  .boutique-intro__container {
    max-width: 800px;
    margin: 0 auto;
  }

  .boutique-intro__heading {
    margin-bottom: var(--space-8);
  }

  .boutique-intro__text {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-charcoal);
  }

  /* SECTION 2: Services Grid - Core Categories */
  .service-categories {
    padding: var(--space-16) var(--space-6);
    background-color: white;
  }

  .service-categories__container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .service-categories__title {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .service-categories__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid #e0e0e0;
    border-bottom: 1px solid #e0e0e0;
  }

  @media (min-width: 768px) {
    .service-categories__list {
      grid-template-columns: repeat(2, 1fr);
      border-right: 1px solid #e0e0e0;
    }
  }

  @media (min-width: 1024px) {
    .service-categories__list {
      grid-template-columns: repeat(5, 1fr);
      border-right: none;
    }
  }

  .service-category {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-8) var(--space-6);
    border-bottom: 1px solid #e0e0e0;
    border-right: 1px solid #e0e0e0;
    text-decoration: none;
    transition: background-color var(--transition-fast);
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .service-category:nth-child(even) {
      border-right: none;
    }
  }

  @media (min-width: 1024px) {
    .service-category {
      border-right: 1px solid #e0e0e0;
    }
    .service-category:last-child {
      border-right: none;
    }
  }

  .service-category:hover {
    background-color: #fafafa;
  }

  .service-category:last-child {
    border-bottom: none;
  }

  .service-category__content {
    margin-bottom: var(--space-4);
  }

  .service-category__title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-black);
    margin-bottom: var(--space-3);
  }

  .service-category__description {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-gray-dark);
  }

  .service-category__arrow {
    font-size: 1.25rem;
    color: var(--color-gold);
    transition: color var(--transition-fast), transform var(--transition-fast);
    align-self: flex-start;
  }

  .service-category:hover .service-category__arrow {
    color: var(--color-black);
    transform: translateX(4px);
  }

  /* SECTION 3: Approach */
  .approach-section {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-ivory);
  }

  .approach-section__container {
    max-width: 900px;
    margin: 0 auto;
  }

  .approach-section__title {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .approach-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 768px) {
    .approach-section__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8);
    }
  }

  .approach-item {
    text-align: center;
  }

  .approach-item h3 {
    font-size: 1.125rem;
    margin-bottom: var(--space-3);
  }

  .approach-item p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-gray-dark);
  }

  /* SECTION 4: Reviews */
  .reviews-section {
    padding: var(--space-16) var(--space-6);
    background-color: white;
  }

  .reviews-section__container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .reviews-section__title {
    text-align: center;
    margin-bottom: var(--space-2);
  }

  .reviews-section__subtitle {
    text-align: center;
    font-size: 0.9375rem;
    color: var(--color-gray-medium);
    margin-bottom: var(--space-12);
  }

  .reviews-section__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .reviews-section__cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .reviews-section__cta {
    text-align: center;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-gold);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .section-link:hover {
    color: var(--color-black);
  }

  /* SECTION 5: Final CTA */
  .final-cta {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-ivory);
  }

  .final-cta__container {
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
  }

  .final-cta__heading {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 6vw, 3rem);
    color: var(--color-black);
    margin-bottom: var(--space-3);
  }

  .final-cta__subheading {
    font-size: 1.0625rem;
    color: var(--color-gray-dark);
    margin-bottom: var(--space-8);
    line-height: 1.6;
  }

  /* NOTE: .button-row is defined in global.css - reused here */

  /* Success banner (preserved from original) */
  .submission-success-banner {
    padding: var(--space-4) var(--space-6);
    margin: var(--space-4) var(--space-6) var(--space-8);
    background-color: #f0f9f4;
    border-left: 4px solid #22c55e;
    border-radius: 2px;
  }

  .submission-success-banner__text {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #166534;
  }

  /* ═══════════════════════════════════════════════════════════════ */
  /* SECTION 1: VISUAL DISCOVERY - PRIMARY SHOPPING GRID */
  /* ═══════════════════════════════════════════════════════════════ */

  .visual-discovery {
    padding: var(--space-16) var(--space-6);
    background-color: white;
  }

  .visual-discovery__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Pill Navigation */
  .discovery-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .discovery-pills {
      gap: var(--space-6);
    }
  }

  .pill {
    display: inline-block;
    padding: 0.75rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.25px;
    text-decoration: none;
    color: var(--color-black);
    background-color: transparent;
    border: 1px solid color-mix(in srgb, var(--color-black) 15%, transparent);
    border-radius: 24px;
    transition: all var(--transition-fast);
    cursor: pointer;
  }

  .pill:hover {
    background-color: var(--color-black);
    color: white;
    border-color: var(--color-black);
  }

  /* Discovery Grid - Clean, Balanced Layout */
  .discovery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .discovery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
  }

  @media (min-width: 1024px) {
    .discovery-grid {
      grid-template-columns: repeat(5, 1fr);
      gap: var(--space-6);
    }
  }

  /* Visual Card - Primary Shopping Cards (Immersive Editorial Style) */
  .visual-card {
    position: relative;
    display: block;
    text-decoration: none;
    border-radius: 12px;
    overflow: hidden;
    height: 420px;
    cursor: pointer;
  }

  .visual-card__image-wrapper {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .visual-card__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform var(--transition-normal);
    display: block;
  }

  .visual-card:hover .visual-card__image-wrapper img {
    transform: scale(1.08);
  }

  .visual-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(26, 26, 26, 0.95) 0%,
      rgba(26, 26, 26, 0.5) 50%,
      transparent 100%
    );
    pointer-events: none;
  }

  .visual-card:hover .visual-card__overlay {
    background: linear-gradient(
      to top,
      rgba(26, 26, 26, 0.85) 0%,
      rgba(26, 26, 26, 0.4) 50%,
      transparent 100%
    );
  }

  .visual-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    z-index: 5;
  }

  .visual-card__title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    margin: 0;
    line-height: 1.2;
  }

  .visual-card__cta {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.25px;
    color: rgba(255, 255, 255, 0.95);
    transition: color var(--transition-fast);
    margin: 0;
  }

  .visual-card:hover .visual-card__cta {
    color: white;
  }

  /* ═══════════════════════════════════════════════════════════════ */
  /* SECTION 2B: SECONDARY SERVICES - EVENT PLANNING & FLORALS */
  /* ═══════════════════════════════════════════════════════════════ */

  .secondary-services {
    padding: var(--space-12) var(--space-6);
    background-color: var(--color-ivory);
  }

  .secondary-services__container {
    max-width: 900px;
    margin: 0 auto;
  }

  .secondary-services__title {
    margin-bottom: var(--space-8);
  }

  .secondary-services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .secondary-services__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
  }

  /* Secondary Card - Smaller Editorial Cards (Immersive Style, Lower Visual Weight) */
  .secondary-card {
    position: relative;
    display: block;
    text-decoration: none;
    border-radius: 12px;
    overflow: hidden;
    height: 300px;
    cursor: pointer;
  }

  .secondary-card__image-wrapper {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .secondary-card__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform var(--transition-normal);
    display: block;
  }

  .secondary-card:hover .secondary-card__image-wrapper img {
    transform: scale(1.08);
  }

  .secondary-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(26, 26, 26, 0.90) 0%,
      rgba(26, 26, 26, 0.45) 50%,
      transparent 100%
    );
    pointer-events: none;
  }

  .secondary-card:hover .secondary-card__overlay {
    background: linear-gradient(
      to top,
      rgba(26, 26, 26, 0.80) 0%,
      rgba(26, 26, 26, 0.35) 50%,
      transparent 100%
    );
  }

  .secondary-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-6);
    display: flex;
