---
import BaseLayout from '../../layouts/BaseLayout.astro';

const metadata = {
  title: "Formal Gowns Richmond KY | Evening Wear Vero's Boutique",
  description: "Elegant formal evening gowns in Richmond, Kentucky. Discover luxury formal wear for galas, events, and special occasions at Vero's Boutique.",
};
---

<BaseLayout title={metadata.title} description={metadata.description} robots="noindex">
  <!-- Women's Dress Shop In Richmond Section -->
  <section style="padding: var(--space-16) var(--space-6); background-color: white;">
    <div style="max-width: 900px; margin: 0 auto;">
      <h1 style="font-family: var(--font-serif); font-size: clamp(2rem, 6vw, 3.5rem); font-weight: 500; letter-spacing: -0.5px; margin-bottom: var(--space-6); color: var(--color-black);">
        A Women's Dress Shop in Richmond, KY (With an Online Preview)
      </h1>
      <p style="font-size: 1rem; line-height: 1.8; color: #555; margin-bottom: var(--space-6);">
        Vero's Boutique is more than a women's dress shop—it's a destination. Located in downtown Richmond, Kentucky, we specialize in formal gowns and prom dresses curated specifically for our community. Whether you're from Richmond, Lexington, Nicholasville, or Winchester, our boutique offers what big-box retailers can't: hand-selected inventory, personalized service, and a shopping experience dedicated entirely to finding *your* dress.
      </p>
      <p style="font-size: 1rem; line-height: 1.8; color: #555; margin-bottom: var(--space-6);">
        Many women's dress shopping decisions start online. We get it. Preview our latest collections on our website and social media, then book a 90-minute private fitting appointment at our Richmond location. This hybrid approach—online discovery plus in-person service—is perfect for best women's dress shops in Richmond, KY that respect your time and budget.
      </p>
      <p style="font-size: 1rem; line-height: 1.8; color: #555; margin-bottom: var(--space-8);">
        From Lexington shopping centers to downtown Richmond, the difference is clear: we're a boutique dedicated to helping you feel confident, beautiful, and uniquely yourself. Come experience the Vero's Boutique difference.
      </p>
      <div style="display: flex; gap: var(--space-4); flex-wrap: wrap;">
        <a href="/formal-gowns-richmond-ky/prom-2026/" class="button button--primary">Shop Prom 2026</a>
        <a href="/formal-gowns-richmond-ky/gala-evening/" class="button button--outline">Shop Gala &amp; Evening</a>
        <a href="/formal-gowns-richmond-ky/new-arrivals/" class="button button--outline">New Arrivals</a>
      </div>
    </div>
  </section>
</BaseLayout>
