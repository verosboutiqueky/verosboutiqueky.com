    title="Find Your Perfect Quinceañera Gown"
    subtitle="XV celebration dresses curated for authenticity, beauty, and cultural pride. Expert styling, family-centered fittings, and complete celebration support from Richmond's quinceañera specialists."
    heroImage="/images/quinceanera-dresses-richmond-ky/hero-quinceanera-court-styling.webp"
    imageAlt="Diverse quinceañera celebration with court styling and traditional dress"
    categories={heroCategories}
    primaryCTA={{ text: "Book Fitting", textMobile: "Book", href: "/book-an-appointment/?service=quince-fitting" }}
    secondaryCTA={{ text: "Shop", href: "#quince-collections" }}
  />

  <!-- SECTION 2: BOUTIQUE AUTHORITY -->
