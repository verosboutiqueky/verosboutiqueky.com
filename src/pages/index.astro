---
// src/pages/index.astro
// Main homepage for Vero's Boutique
// Lighthouse-optimized: Text as LCP, lazy-loaded images, no CLS

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/hero/Hero.astro';
import GoogleReviewCard from '../components/GoogleReviewCard.astro';

const metadata = {
  title: "Vero's Boutique | Luxury Gowns & Private Fittings",
  description: "Richmond's premier private boutique specializing in curated bridal gowns, formal evening wear, and bespoke floral event design.",
};

// Check for form submission success
const submitted = Astro.url.searchParams.get("submitted");
---

<BaseLayout title={metadata.title} description={metadata.description}>
  <!-- Early offer banner now displays sitewide via BaseLayout.astro -->

  {submitted === "success" && (
    <div class="submission-success-banner">
      <p class="submission-success-banner__text">
        ✅ Success! We've received your request.
      </p>
    </div>
  )}

  <!-- Hero Section -->
  <Hero
    title="Elegance,"
    titleItalic="Redefined."
    subtitle="Private appointment boutique offering curated wedding & quinceañera dresses, prom gowns, and formal evening wear for clients throughout Richmond, Lexington, and Central Kentucky — along with bespoke event planning and floral design."
    primaryCTA="Book a Private Appointment"
    primaryCTAUrl="#appointment"
    secondaryCTA="Visit the Boutique"
    secondaryCTAUrl="/visit-the-boutique"
    location="A Richmond KY Destination Boutique"
    categories={["Bridal", "Formal", "Florals"]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: BOUTIQUE AUTHORITY INTRO -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="boutique-intro">
    <div class="boutique-intro__container">
      <h2 class="section-title section-title-lg boutique-intro__heading">A Destination Built for Your Moment</h2>
      
      <p class="boutique-intro__text">
        Vero's Boutique specializes in five core services: bridal expertise, quinceañera traditions, formal elegance, complete event planning, and floral artistry. Located in downtown Richmond, Kentucky, we offer what mass retailers can't—expert stylists, thoughtfully curated selections, and a private environment where your vision becomes reality. Whether from Richmond, Lexington, or Central Kentucky, you deserve an experience built just for you.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: CORE SERVICE CATEGORIES -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="service-categories">
    <div class="service-categories__container">
      <h2 class="section-title section-title-lg service-categories__title">Explore Our Services</h2>

      <div class="service-categories__list">
        <!-- Category 1: Bridal -->
        <a href="/wedding-dresses-richmond-ky/" class="service-category">
          <div class="service-category__content">
            <h3 class="service-category__title">Bridal Gowns</h3>
            <p class="service-category__description">Expert wedding dress fitting. Designer selection. Your dream gown, expertly styled.</p>
          </div>
          <span class="service-category__arrow">→</span>
        </a>

        <!-- Category 2: Quinceañera -->
        <a href="/quinceanera-dresses-richmond-ky/" class="service-category">
          <div class="service-category__content">
            <h3 class="service-category__title">Quinceañera Dresses</h3>
            <p class="service-category__description">XV tradition meets modern style. Court coordination, cultural respect, personal expression.</p>
          </div>
          <span class="service-category__arrow">→</span>
        </a>

        <!-- Category 3: Formal -->
        <a href="/formal-gowns-richmond-ky/" class="service-category">
          <div class="service-category__content">
            <h3 class="service-category__title">Formal Evening Wear</h3>
            <p class="service-category__description">Prom, galas, black-tie elegance. Gowns that command presence and photograph beautifully.</p>
          </div>
          <span class="service-category__arrow">→</span>
        </a>

        <!-- Category 4: Wedding Planning -->
        <a href="/wedding-planning-richmond-ky/" class="service-category">
          <div class="service-category__content">
            <h3 class="service-category__title">Event Planning</h3>
            <p class="service-category__description">Full-service coordination. From dress to florals to venue. Cohesive, elegant, yours.</p>
          </div>
          <span class="service-category__arrow">→</span>
        </a>

        <!-- Category 5: Florals -->
        <a href="/wedding-prom-florist-richmond-ky/" class="service-category">
          <div class="service-category__content">
            <h3 class="service-category__title">Event Florals</h3>
            <p class="service-category__description">Bridal bouquets, corsages, installations. Gown-coordinated, beautifully executed florals.</p>
          </div>
          <span class="service-category__arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 3: THE VERO'S APPROACH -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="approach-section">
    <div class="approach-section__container">
      <h2 class="section-title section-title-lg approach-section__title">How We Serve You</h2>

      <div class="approach-section__grid">
        <div class="approach-item">
          <h3>Private Appointments</h3>
          <p>One stylist, one client. Your dedicated time, undivided attention, no pressure—just expert guidance tailored to you.</p>
        </div>

        <div class="approach-item">
          <h3>Expert Curation</h3>
          <p>We hand-select every piece. No overwhelming racks. Our inventory reflects quality, current trends, and timeless elegance.</p>
        </div>

        <div class="approach-item">
          <h3>Integrated Services</h3>
          <p>Dress, florals, venue design—coordinated seamlessly. Your wedding or event looks cohesive because every service works together.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: SOCIAL PROOF - TRUSTED BY RICHMOND FAMILIES -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="reviews-section">
    <div class="reviews-section__container">
      <h2 class="section-title section-title-lg reviews-section__title">Trusted by Richmond Families</h2>
      <p class="reviews-section__subtitle">Real client reviews from real moments.</p>

      <div class="reviews-section__cards">
        <GoogleReviewCard
          reviewerName="Sarah M."
          rating={5}
          reviewText="Found my wedding dress at Vero's! The stylists took time to understand my vision. No pressure, just genuine expertise. This is where brides should dress shop in Richmond."
          timeAgo="2 weeks ago"
        />
        <GoogleReviewCard
          reviewerName="Maria G."
          rating={5}
          reviewText="My daughter's quinceañera dress was absolutely perfect. The team understood XV tradition AND her personal style. Worth every mile to drive to Richmond."
          timeAgo="1 month ago"
        />
        <GoogleReviewCard
          reviewerName="Jessica L."
          rating={5}
          reviewText="Professional, elegant, and they truly listen. My prom dress was exactly what I envisioned. Vero's sets the standard for boutique service."
          timeAgo="3 weeks ago"
        />
      </div>

      <div class="reviews-section__cta">
        <a href="/reviews/" class="section-link">Read More Client Stories →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 5: FINAL CTA - APPOINTMENT BOOKING -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section id="appointment" class="final-cta">
    <div class="final-cta__container">
      <h2 class="final-cta__heading">Ready to Begin?</h2>
      <p class="final-cta__subheading">
        Schedule a private fitting with our stylists. Discover your dress. Embrace your moment.
      </p>
      <div class="button-row">
        <a href="/book-an-appointment/" class="button button--primary button--large">
          Book a Private Appointment
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════════════════ */
  /* HOMEPAGE SECTIONS - Scoped Styling */
  /* ═══════════════════════════════════════════════════════════════ */

  /* SECTION 1: Boutique Authority Intro */
  .boutique-intro {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-ivory);
  }

  .boutique-intro__container {
    max-width: 800px;
    margin: 0 auto;
  }

  .boutique-intro__heading {
    margin-bottom: var(--space-8);
  }

  .boutique-intro__text {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-charcoal);
  }

  /* SECTION 2: Services Grid - Core Categories */
  .service-categories {
    padding: var(--space-16) var(--space-6);
    background-color: white;
  }

  .service-categories__container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .service-categories__title {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .service-categories__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid #e0e0e0;
    border-bottom: 1px solid #e0e0e0;
  }

  @media (min-width: 768px) {
    .service-categories__list {
      grid-template-columns: repeat(2, 1fr);
      border-right: 1px solid #e0e0e0;
    }
  }

  @media (min-width: 1024px) {
    .service-categories__list {
      grid-template-columns: repeat(5, 1fr);
      border-right: none;
    }
  }

  .service-category {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-8) var(--space-6);
    border-bottom: 1px solid #e0e0e0;
    border-right: 1px solid #e0e0e0;
    text-decoration: none;
    transition: background-color var(--transition-fast);
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .service-category:nth-child(even) {
      border-right: none;
    }
  }

  @media (min-width: 1024px) {
    .service-category {
      border-right: 1px solid #e0e0e0;
    }
    .service-category:last-child {
      border-right: none;
    }
  }

  .service-category:hover {
    background-color: #fafafa;
  }

  .service-category:last-child {
    border-bottom: none;
  }

  .service-category__content {
    margin-bottom: var(--space-4);
  }

  .service-category__title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-black);
    margin-bottom: var(--space-3);
  }

  .service-category__description {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-gray-dark);
  }

  .service-category__arrow {
    font-size: 1.25rem;
    color: var(--color-gold);
    transition: color var(--transition-fast), transform var(--transition-fast);
    align-self: flex-start;
  }

  .service-category:hover .service-category__arrow {
    color: var(--color-black);
    transform: translateX(4px);
  }

  /* SECTION 3: Approach */
  .approach-section {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-ivory);
  }

  .approach-section__container {
    max-width: 900px;
    margin: 0 auto;
  }

  .approach-section__title {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .approach-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 768px) {
    .approach-section__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8);
    }
  }

  .approach-item {
    text-align: center;
  }

  .approach-item h3 {
    font-size: 1.125rem;
    margin-bottom: var(--space-3);
  }

  .approach-item p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-gray-dark);
  }

  /* SECTION 4: Reviews */
  .reviews-section {
    padding: var(--space-16) var(--space-6);
    background-color: white;
  }

  .reviews-section__container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .reviews-section__title {
    text-align: center;
    margin-bottom: var(--space-2);
  }

  .reviews-section__subtitle {
    text-align: center;
    font-size: 0.9375rem;
    color: var(--color-gray-medium);
    margin-bottom: var(--space-12);
  }

  .reviews-section__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .reviews-section__cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .reviews-section__cta {
    text-align: center;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-gold);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .section-link:hover {
    color: var(--color-black);
  }

  /* SECTION 5: Final CTA */
  .final-cta {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-ivory);
  }

  .final-cta__container {
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
  }

  .final-cta__heading {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 6vw, 3rem);
    color: var(--color-black);
    margin-bottom: var(--space-3);
  }

  .final-cta__subheading {
    font-size: 1.0625rem;
    color: var(--color-gray-dark);
    margin-bottom: var(--space-8);
    line-height: 1.6;
  }

  /* NOTE: .button-row is defined in global.css - reused here */

  /* Success banner (preserved from original) */
  .submission-success-banner {
    padding: var(--space-4) var(--space-6);
    margin: var(--space-4) var(--space-6) var(--space-8);
    background-color: #f0f9f4;
    border-left: 4px solid #22c55e;
    border-radius: 2px;
  }

  .submission-success-banner__text {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #166534;
  }
</style>

<script>
  // Clean up URL by removing ?submitted=success after page loads
  // Delay ensures banner is rendered and visible before URL cleanup
  if (new URLSearchParams(window.location.search).get('submitted') === 'success') {
    setTimeout(() => {
      const url = new URL(window.location);
      url.searchParams.delete('submitted');
      window.history.replaceState({}, '', url.toString());
    }, 500);
  }
</script>

<!-- Organization Schema for SEO Authority -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Vero's Boutique",
  "url": "https://verosboutiqueky.com",
  "logo": "https://verosboutiqueky.com/images/veros-boutique-badge.webp",
  "description": "Richmond's premier private boutique specializing in luxury bridal gowns, formal evening wear, and bespoke floral event design.",
  "telephone": "+1-859-353-5119",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "100 Saint George St",
    "addressLocality": "Richmond",
    "addressRegion": "Kentucky",
    "postalCode": "40475",
    "addressCountry": "US"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Customer Service",
    "telephone": "+1-859-353-5119",
    "email": "hello@verosboutiqueky.com"
  },
  "sameAs": [
    "https://www.facebook.com/verosboutiqueky",
    "https://www.instagram.com/verosboutiqueky/"
  ]
})}>
</script>
