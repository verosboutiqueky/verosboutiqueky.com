---
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/hero/Hero.astro';

// Import hero image
import weddingPlanningCouple from '../../assets/wedding-planning-couple.webp';

// Import optimized WebP assets from src/assets
import weddingVenue1 from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/wedding-venue-1.webp';
import weddingVenue2 from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/wedding-venue-2.webp';
import weddingVenue3 from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/wedding-venue-3.webp';
import venueChenault from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/venue-chenault.webp';
import venueCeremonySetup from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/venue-ceremony-setup.webp';
import venueReceptionSetup from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/venue-reception-setup.webp';
import venueTransformationDetails from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/venue-transformation-details.webp';
import celebrationMoment from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/celebration-moment.webp';
import curatedStylingDetails from '../../assets/event-planning-quinceaneras-weddings-richmond-ky/curated-styling-details.webp';

const metadata = {
  title: "Wedding Planning & Coordination Richmond KY | Madison County",
  description: "Full-service wedding planning and month-of coordination in Richmond, Kentucky. Gown selection, vendor management, decor design, and seamless execution.",
};

// Generate OG image for social sharing
const og = await getImage({
  src: venueChenault,
  width: 1200,
  height: 630,
  format: "webp",
  fit: "cover",
});
---

<BaseLayout title={metadata.title} description={metadata.description} ogImage={og.src}>
  <!-- ===================================================================
       HERO SECTION
       =================================================================== -->
  <Hero
    title="Wedding Planning"
    titleItalic="in Richmond, Kentucky"
    subtitle="Full-service wedding planning, design, and coordination for couples across Richmond and Central Kentucky. From concept to seamless execution."
    primaryCTA="Book a Planning Consultation"
    primaryCTAUrl="/book-an-appointment?service=wedding-planning"
    secondaryCTA="Explore Wedding Services"
    secondaryCTAUrl="#packages-section"
    location="Complete Wedding Coordination"
    heroImage={weddingPlanningCouple.src}
  />

  <!-- ===================================================================
       WEDDING COORDINATION SECTION
       =================================================================== -->
  <section id="wedding-coordination" class="wedding-coordination-section">
    <div class="container">
      <h2 style="text-align: center;">Wedding Coordination & Design in Madison County</h2>
      
      <p class="section-intro" style="text-align: center;">
        Whether you're coordinating month-of details or need full planning from day one, Vero's Boutique 
        simplifies the wedding planning journey. From vendor communication and design decisions to day-of 
        execution, we ensure your wedding flows seamlessly while your gown and decor work together in perfect 
        aesthetic harmony. Multiple planning tiers available, from coordination to full production.
      </p>

      <div style="max-width: 90ch; margin: var(--space-8) auto var(--space-12); padding: var(--space-8); background-color: color-mix(in srgb, var(--color-gold) 5%, transparent); border-left: 4px solid var(--color-gold); border-radius: 4px;">
        <p style="text-align: left; color: var(--color-charcoal); line-height: var(--lh-loose); font-size: var(--text-secondary);">
          <strong>The Outcome:</strong> You'll get a cohesive aesthetic where your gown, florals, linens, and decor complement each other seamlessly. We manage vendor timelines, handle design decisions, and execute the day-of logistics so you can focus on celebration instead of stress. From month-of coordination to full planning, you'll experience reduced vendor chaos, better aesthetics, and seamless execution.
        </p>
      </div>

      <!-- Coordination services -->
      <div class="coordination-services">
        <h3 style="text-align: center;">Wedding Planning Services</h3>
        <div class="services-grid">
          <div class="service-item">
            <div class="service-icon">📋</div>
            <h4>Month-of Coordination</h4>
            <ul class="service-list">
              <li>Final vendor confirmations</li>
              <li>Timeline development</li>
              <li>Day-of ceremony management</li>
              <li>Vendor coordination</li>
              <li>Budget reconciliation</li>
            </ul>
          </div>
          <div class="service-item">
            <div class="service-icon">🎨</div>
            <h4>Decor & Design Styling</h4>
            <ul class="service-list">
              <li>Centerpiece curation</li>
              <li>Floral coordination</li>
              <li>Lighting & ambiance</li>
              <li>Gown-to-decor alignment</li>
              <li>Venue layout design</li>
            </ul>
          </div>
          <div class="service-item">
            <div class="service-icon">👗</div>
            <h4>Gown & Aesthetic Alignment</h4>
            <ul class="service-list">
              <li>Gown selection guidance</li>
              <li>Color palette coordination</li>
              <li>Bridal party styling</li>
              <li>Floral design selection</li>
              <li>Cohesive aesthetic creation</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Related links -->
      <div class="coordination-links">
        <p style="text-align: center;">Looking for bridal gowns or event florals? Explore our integrated services:</p>
        <div class="links-grid">
          <a href="/wedding-dresses-richmond-ky" class="link-card">
            <span class="link-icon">👗</span>
            <span class="link-text">Wedding Dresses & Bridal Gowns</span>
          </a>
          <a href="/wedding-prom-florist-richmond-ky" class="link-card">
            <span class="link-icon">🌸</span>
            <span class="link-text">Wedding Florals & Event Design</span>
          </a>
        </div>
      </div>

      <!-- Wedding gallery -->
      <div class="wedding-gallery">
        <h3 style="text-align: center;">Wedding Transformations in Central Kentucky</h3>
        <div class="gallery-grid">
          <div class="gallery-item">
            <img
              src={weddingVenue1.src}
              alt="Wedding venue decor Madison County Kentucky - elegant ceremony setup with floral design"
              width={600}
              height={450}
              loading="lazy"
              decoding="async"
              class="gallery-image"
            />
            <p class="gallery-label">Elegant Ceremony Setup</p>
          </div>
          <div class="gallery-item">
            <img
              src={weddingVenue2.src}
              alt="Wedding reception design Richmond Kentucky - tables, lighting, and decor transformation"
              width={600}
              height={450}
              loading="lazy"
              decoding="async"
              class="gallery-image"
            />
            <p class="gallery-label">Reception Transformation</p>
          </div>
          <div class="gallery-item">
            <img
              src={weddingVenue3.src}
              alt="Wedding detail and styling Richmond Kentucky - florals, linens, centerpieces, and styling"
              width={600}
              height={450}
              loading="lazy"
              decoding="async"
              class="gallery-image"
            />
            <p class="gallery-label">Curated Details</p>
          </div>
        </div>
      </div>

      <!-- Wedding CTA -->
      <div class="wedding-cta" style="text-align: center;">
        <h3 style="text-align: center;">Let's Plan Your Perfect Wedding Day</h3>
        <a href="/book-an-appointment?service=wedding-coordination" class="button button--primary">
          Schedule Wedding Consultation
        </a>
      </div>
    </div>
  </section>

  <!-- ===================================================================
       INTEGRATED ADVANTAGE (Differentiator)
       =================================================================== -->
  <section id="integrated-advantage" class="advantage-section">
    <div class="container">
      <h2 style="text-align: center;">Where Couture Meets Production Design</h2>
      
      <p class="advantage-excerpt" style="text-align: center;">
        Most event planners and florists work separately. You pick a gown, then search for florals. 
        You coordinate decor details, then realize they don't match your dress. We eliminate that gap. 
        At Vero's Boutique, your selected gown becomes the design anchor. We build florals, linens, lighting, 
        and styling around it, ensuring every element complements your couture—creating the cohesive, 
        editorial-quality aesthetic that independent planners often can't deliver.
      </p>

      <div class="advantage-points">
        <div class="advantage-point" style="text-align: center;">
          <h4>🎯 Gown-Centric Design</h4>
          <p style="text-align: center;">Your dress drives the entire aesthetic, not the other way around.</p>
        </div>
        <div class="advantage-point" style="text-align: center;">
          <h4>✨ Unified Execution</h4>
          <p style="text-align: center;">One expert team handles gown selection, florals, decor, and styling—no coordination gaps.</p>
        </div>
        <div class="advantage-point" style="text-align: center;">
          <h4>🏻 Editorial-Quality Results</h4>
          <p style="text-align: center;">Every detail is curated with luxury boutique expertise, not generic templates.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================================
       PRICING PACKAGES SECTION
       =================================================================== -->
  <section id="packages-section" class="pricing-section">
    <div class="container">
      <h2 style="text-align: center;">Wedding Planning Packages</h2>
      
      <p class="pricing-intro" style="text-align: center;">
        Transparent planning based on scope and vision. Our flexible tiers adapt to your wedding's 
        needs. Final investment varies with guest count, venue, seasonality, installation complexity, and travel. 
        Request a custom proposal after consultation.
      </p>

      <div class="pricing-cards">
        <div class="pricing-card">
          <h3>Essential Management</h3>
          <p class="pricing-card__description">Day-of Coordination & Vendor Oversight</p>
          <ul class="pricing-card__features">
            <li>Final 30-day timeline & checklist</li>
            <li>Vendor confirmations & contact sheet</li>
            <li>Day-of ceremony & reception oversight</li>
            <li>Real-time problem solving</li>
            <li>Setup & breakdown coordination</li>
          </ul>
        </div>

        <div class="pricing-card">
          <h3>Signature Series</h3>
          <p class="pricing-card__description">Partial Planning + Decor Styling</p>
          <ul class="pricing-card__features">
            <li>Vendor recommendations & confirmations</li>
            <li>Design concept & color palette</li>
            <li>Gown selection guidance</li>
            <li>Floral design coordination</li>
            <li>Decor & styling curation</li>
            <li>Day-of coordination</li>
          </ul>
        </div>

        <div class="pricing-card">
          <h3>Royal Production</h3>
          <p class="pricing-card__description">Full Planning + Custom Decor</p>
          <ul class="pricing-card__features">
            <li>Complete wedding planning from concept</li>
            <li>Venue selection & contract negotiation</li>
            <li>Full vendor management</li>
            <li>Custom decor & floral design</li>
            <li>Gown & bridal party styling</li>
            <li>Setup & day-of execution</li>
            <li>Post-wedding follow-up</li>
          </ul>
        </div>
      </div>

      <p class="pricing-note" style="text-align: center;">
        <strong>What Affects Final Investment:</strong> Guest count, venue selection, decor complexity, 
        seasonal availability, custom installations, and travel distance to venue. Contact us for a transparent 
        consultation and custom proposal tailored to your celebration.
      </p>
    </div>
  </section>

  <!-- ===================================================================
       FAQ SECTION (Wedding-Specific)
       =================================================================== -->
  <section id="faq" class="faq-section">
    <div class="container">
      <h2 style="text-align: center;">Wedding Planning FAQs</h2>

      <div class="faq-grid">
        <div class="faq-item">
          <h3>Do I need a wedding planner for a small wedding?</h3>
          <p>
            Even small weddings benefit from professional coordination. A planner manages vendor timelines, 
            design decisions, and day-of execution—freeing you to enjoy your celebration. Vero's Boutique 
            offers flexible planning packages for intimate ceremonies. Couples report lower stress, better 
            aesthetics, and seamless execution. Whether your wedding is 25 guests or 250, we have a planning 
            package designed for you.
          </p>
        </div>

        <div class="faq-item">
          <h3>How far in advance should I book wedding planning?</h3>
          <p>
            Weddings benefit from 6–12 months lead time for full planning. However, we accommodate month-of coordination 
            packages for shorter timelines. Contact us as soon as your date is confirmed to ensure availability and 
            allow thoughtful design planning.
          </p>
        </div>

        <div class="faq-item">
          <h3>Can I bundle my gown and planning services?</h3>
          <p>
            Absolutely. One of our key advantages is integrated service—gown selection, event planning, 
            and floral design in one place. Bundle your wedding dress with planning services for cohesive 
            aesthetic alignment and simplified coordination. Ask about package options during your consultation.
          </p>
        </div>

        <div class="faq-item">
          <h3>What's the difference between month-of coordination and full planning?</h3>
          <p>
            Month-of coordination (Essential Management) handles final logistics and day-of execution. Full planning 
            (Signature Series, Royal Production) includes 6–12 months of vendor selection, design concept development, 
            gown and floral guidance, and custom decor curation. Choose based on timeline and scope.
          </p>
        </div>

        <div class="faq-item">
          <h3>Can you work with our existing wedding vendors?</h3>
          <p>
            Yes. We coordinate seamlessly with your selected vendors. Bring your florist, venue, or caterer—we manage vendor communication, 
            timing, and design alignment. If you need recommendations, we have trusted local partners ready to collaborate.
          </p>
        </div>

        <div class="faq-item">
          <h3>How does gown selection affect your overall wedding design?</h3>
          <p>
            Your gown is the design anchor. We curate florals, linens, lighting, color palette, and bridal party styling around your 
            dress to create editorial-quality aesthetic. Unlike separate florists or planners, we ensure every element complements 
            your couture from concept to execution.
          </p>
        </div>
      </div>

      <div class="faq-cta" style="text-align: center;">
        <p style="text-align: center;">Looking for general event planning FAQs?</p>
        <a href="/event-planning-richmond-ky/" class="button button--outline">Back to Event Planning Overview</a>
      </div>
    </div>
  </section>

  <!-- ===================================================================
       FINAL CTA SECTION
       =================================================================== -->
  <section class="final-cta-section">
    <div class="container" style="text-align: center;">
      <h2 style="text-align: center;">Ready to Plan Your Wedding Day?</h2>
      <p style="text-align: center;">
        Let's create a beautiful, stress-free wedding experience. From concept to execution, 
        we'll handle every detail while you focus on celebrating your love.
      </p>
      <div style="text-align: center;">
        <a href="/book-an-appointment?service=wedding-coordination" class="button button--primary button--large">
          Schedule Your Wedding Consultation
        </a>
      </div>
    </div>
  </section>

  <!-- ===================================================================
       GEO-EXPANSION LINE
       =================================================================== -->
  <section class="geo-section">
    <div class="container">
      <p class="geo-text" style="text-align: center;">
        <strong>Serving</strong> Richmond, Berea, Lexington, and surrounding Central Kentucky communities 
        with full-service wedding planning, coordination, and design.
      </p>
    </div>
  </section>
</BaseLayout>

<!-- ===================================================================
     STRUCTURED DATA / SCHEMA MARKUP
     =================================================================== -->

